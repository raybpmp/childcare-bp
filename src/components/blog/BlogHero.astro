---
import type { CollectionEntry } from "astro:content";

import { getCategoryStyle } from "@/config/blog";

interface Props {
    post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { title, excerpt, coverImage, category } = post.data;
const cover = coverImage || "/images/blog/default-cover.jpg";

const categoryClass = getCategoryStyle(category);
---

<div class="blog-hero-card">
    <a
        href={`/blog/${post.slug}`}
        class="block md:grid md:grid-cols-2 md:gap-8 md:items-center group"
    >
        <!-- Image -->
        <div class="aspect-[16/9] md:aspect-square overflow-hidden">
            <img
                src={cover}
                alt={title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="eager"
            />
        </div>

        <!-- Content -->
        <div class="p-6 md:p-8">
            {
                category && (
                    <span
                        class={`inline-block px-3 py-1 md:px-4 md:py-2 rounded-full text-xs md:text-sm font-semibold mb-3 md:mb-4 ${categoryClass}`}
                    >
                        Featured: {category}
                    </span>
                )
            }

            <h2
                class="text-2xl md:text-4xl font-bold text-gray-900 mb-3 md:mb-4 group-hover:text-teal-600 transition-colors"
            >
                {title}
            </h2>

            <p class="text-base md:text-lg text-gray-600 mb-4 md:mb-6">
                {excerpt}
            </p>

            <span
                class="inline-flex items-center gap-2 text-teal-600 font-semibold text-sm md:text-base group-hover:gap-3 transition-all"
            >
                Read Article
                <svg
                    class="w-4 h-4 md:w-5 md:h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </span>
        </div>
    </a>
</div>
