---
import { Container } from "../layout/Container";
import { MapPin, ClipboardCheck, Users, Banknote, ArrowRight } from "lucide-react";

const factors = [
    { label: "Location", icon: MapPin, desc: "Zoning & space", color: "text-blue-500" },
    { label: "Licensing", icon: ClipboardCheck, desc: "State mandates", color: "text-purple-500" },
    { label: "Staffing", icon: Users, desc: "Ratios & quals", color: "text-teal-500" },
    { label: "Investment", icon: Banknote, desc: "Startup costs", color: "text-amber-500" }
];
---

<!-- SEO SECTION 2: Licensing & Costs -->
<section class="pro-section bg-white/50">
    <Container size="lg">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12 items-center">
            <div>
                <span class="pro-text-meta mb-2 block">The Reality</span>
                <h2 class="text-xl md:text-3xl font-bold text-gray-900 mb-2 md:mb-4">
                    Daycare Licensing & Startup Costs
                </h2>
                <div class="space-y-3 text-sm md:text-base text-gray-600 mb-4 md:mb-6 leading-relaxed">
                    <p>
                        Every state has its own rules. Costs vary wildly depending on where you are and what you're building. That's why generic advice feels so confusing—it wasn't written for you.
                    </p>
                    <p class="hidden md:block">
                        You deserve to see what it actually looks like for <em>your</em> state, <em>your</em> capacity, <em>your</em> vision.
                    </p>
                </div>
                <a href="#calculator" class="inline-flex items-center gap-1.5 text-purple-600 hover:text-purple-700 font-bold text-sm md:text-base group">
                    See what's possible for you
                    <ArrowRight className="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
                </a>
            </div>

            <div class="grid grid-cols-2 gap-2 md:gap-4">
                {factors.map((factor) => (
                    <div class="pro-card text-center flex flex-col items-center group hover:border-purple-200 transition-colors">
                        <div class={`mb-2 md:mb-3 p-1.5 rounded-lg bg-gray-50 group-hover:bg-purple-50 transition-colors ${factor.color}`}>
                            <factor.icon className="w-4 h-4 md:w-5 md:h-5" />
                        </div>
                        <h4 class="font-bold text-gray-900 text-xs md:text-sm mb-0.5">{factor.label}</h4>
                        <p class="text-[10px] md:text-xs text-gray-500 md:block hidden">{factor.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </Container>
</section>
