---
import Layout from '../layouts/Layout.astro';
import GlassCard from '../components/ui/GlassCard.astro';

const funnel = Astro.url.searchParams.get('funnel') || 'startup';
const isStartup = funnel === 'startup';
---

<Layout title="Check Your Email | ChildcareBusinessPlan.com">
	<main class="min-h-screen flex items-center justify-center p-4">
		<div class="max-w-2xl w-full">
			<div class="glass-panel rounded-3xl p-12 text-center">
				<div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
					<svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
					</svg>
				</div>

				<h1 class="text-4xl font-bold text-gray-900 mb-4">
					Check Your Email!
				</h1>
				<p class="text-xl text-gray-600 mb-8">
					Your {isStartup ? 'Startup' : 'Growth'} Toolkit is on its way.
				</p>

				<div class="text-left mb-8">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">What's Next?</h2>
					<div class="space-y-4">
						<GlassCard>
							<h3 class="font-bold text-gray-900 mb-2">1. Check your inbox</h3>
							<p class="text-sm text-gray-600">Look for an email from ChildcareBusinessPlan.com (check spam if needed)</p>
						</GlassCard>

						<GlassCard>
							<h3 class="font-bold text-gray-900 mb-2">2. Download your toolkit</h3>
							<p class="text-sm text-gray-600">Click the link to access your spreadsheets and templates</p>
						</GlassCard>

						<GlassCard>
							<h3 class="font-bold text-gray-900 mb-2">3. Want more help?</h3>
							<p class="text-sm text-gray-600 mb-3">
								{isStartup 
									? "Join our Founder Community ($99/mo) for weekly Q&A and support" 
									: "Book a $500 Owner Audit to review your numbers"}
							</p>
							<a 
								href={isStartup ? "/community" : "/audit"} 
								class="inline-block text-brand-600 font-semibold hover:text-brand-700 text-sm"
							>
								Learn More →
							</a>
						</GlassCard>
					</div>
				</div>

				<a href="/" class="text-gray-500 hover:text-gray-700 text-sm">
					← Back to Home
				</a>
			</div>
		</div>
	</main>
</Layout>
