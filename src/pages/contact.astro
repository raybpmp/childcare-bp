---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import HeroImage from "../components/ui/HeroImage.astro";
import GlassCard from "../components/ui/GlassCard.astro";
---

<Layout
    title="Contact Us | ChildcareBusinessPlan.com"
    description="Get in touch with the ChildcareBusinessPlan.com team. We're here to help you build and grow your childcare business."
>
    <!-- Hero Section -->
    <section class="pt-8 pb-12 md:pt-12 md:pb-20">
        <Container size="lg">
            <HeroImage
                src="/images/company/contact.webp"
                alt="Contact the Childcare Business Plan Professional Support Team"
                className="mb-8 md:mb-12"
            />
            <div
                class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-12 text-center mb-8 md:mb-12"
            >
                <span
                    class="inline-block px-3 py-1 md:px-4 rounded-full bg-teal-100 text-teal-700 text-xs md:text-sm font-semibold mb-4 md:mb-6"
                >
                    Get In Touch
                </span>
                <h1
                    class="text-2xl md:text-5xl font-bold text-gray-900 mb-4 md:mb-6"
                >
                    We'd Love to<br />
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-teal-500 to-teal-700"
                        >Hear From You</span
                    >
                </h1>
                <p class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto">
                    Have questions about starting your daycare? Need guidance on
                    growing your childcare business? We're here to help.
                </p>
            </div>
        </Container>
    </section>

    <!-- Contact Options Section -->
    <section class="py-8 md:py-16">
        <Container size="lg">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
                <!-- Contact Form Card -->
                <div class="glass-panel rounded-2xl p-6 md:p-8">
                    <h2
                        class="text-xl md:text-2xl font-bold text-gray-900 mb-4 md:mb-6"
                    >
                        Send Us a Message
                    </h2>
                    <form class="space-y-4 md:space-y-5" id="contact-form">
                        <div>
                            <label
                                for="name"
                                class="block text-sm font-medium text-gray-700 mb-1.5"
                                >Your Name</label
                            >
                            <input
                                type="text"
                                id="name"
                                name="name"
                                required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white/60 text-gray-900 text-sm md:text-base focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-all"
                                placeholder="Jane Doe"
                            />
                        </div>
                        <div>
                            <label
                                for="email"
                                class="block text-sm font-medium text-gray-700 mb-1.5"
                                >Email Address</label
                            >
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white/60 text-gray-900 text-sm md:text-base focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-all"
                                placeholder="jane@example.com"
                            />
                        </div>
                        <div>
                            <label
                                for="subject"
                                class="block text-sm font-medium text-gray-700 mb-1.5"
                                >Subject</label
                            >
                            <select
                                id="subject"
                                name="subject"
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white/60 text-gray-900 text-sm md:text-base focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-all"
                            >
                                <option value="general">General Inquiry</option>
                                <option value="startup"
                                    >Starting a Daycare</option
                                >
                                <option value="growth">Business Growth</option>
                                <option value="tools">Tools & Resources</option>
                                <option value="partnership">Partnership</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div>
                            <label
                                for="message"
                                class="block text-sm font-medium text-gray-700 mb-1.5"
                                >Your Message</label
                            >
                            <textarea
                                id="message"
                                name="message"
                                rows="4"
                                required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white/60 text-gray-900 text-sm md:text-base focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition-all resize-none"
                                placeholder="How can we help you today?"
                            ></textarea>
                        </div>
                        <button
                            type="submit"
                            class="w-full inline-flex items-center justify-center rounded-xl bg-teal-600 hover:bg-teal-700 text-white text-sm md:text-base font-medium px-6 py-3.5 shadow-lg shadow-teal-600/20 transition-all hover:shadow-xl hover:shadow-teal-600/30"
                        >
                            Send Message
                            <svg
                                class="ml-2 w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                            </svg>
                        </button>
                    </form>

                    <!-- Success Message (hidden by default) -->
                    <div id="success-message" class="hidden text-center py-8">
                        <div
                            class="w-16 h-16 bg-gradient-to-br from-teal-400 to-teal-600 rounded-full flex items-center justify-center text-white text-2xl mx-auto mb-4"
                        >
                            ✓
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 mb-2">
                            Message Sent!
                        </h3>
                        <p class="text-sm text-gray-600">
                            We'll get back to you as soon as possible.
                        </p>
                    </div>
                </div>

                <!-- Contact Info & FAQ -->
                <div class="space-y-4 md:space-y-6">
                    <GlassCard>
                        <div class="flex items-start gap-4">
                            <div
                                class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-teal-400 to-teal-600 rounded-xl flex items-center justify-center text-white text-lg md:text-xl flex-shrink-0"
                            >
                                📧
                            </div>
                            <div>
                                <h3
                                    class="font-semibold text-gray-900 text-sm md:text-base mb-1"
                                >
                                    Email Support
                                </h3>
                                <p class="text-xs md:text-sm text-gray-600">
                                    For general inquiries and support, use the
                                    contact form or reach out via email. We
                                    typically respond within 24-48 hours.
                                </p>
                            </div>
                        </div>
                    </GlassCard>

                    <GlassCard>
                        <div class="flex items-start gap-4">
                            <div
                                class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-amber-400 to-orange-500 rounded-xl flex items-center justify-center text-white text-lg md:text-xl flex-shrink-0"
                            >
                                ⏰
                            </div>
                            <div>
                                <h3
                                    class="font-semibold text-gray-900 text-sm md:text-base mb-1"
                                >
                                    Response Time
                                </h3>
                                <p class="text-xs md:text-sm text-gray-600">
                                    We aim to respond to all inquiries within
                                    1-2 business days. Complex questions may
                                    take a bit longer as we want to give you
                                    thoughtful answers.
                                </p>
                            </div>
                        </div>
                    </GlassCard>

                    <GlassCard>
                        <div class="flex items-start gap-4">
                            <div
                                class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-purple-400 to-indigo-500 rounded-xl flex items-center justify-center text-white text-lg md:text-xl flex-shrink-0"
                            >
                                💡
                            </div>
                            <div>
                                <h3
                                    class="font-semibold text-gray-900 text-sm md:text-base mb-1"
                                >
                                    Quick Tip
                                </h3>
                                <p class="text-xs md:text-sm text-gray-600">
                                    Before reaching out, check our
                                    <a
                                        href="/starting-a-daycare"
                                        class="text-teal-600 hover:text-teal-700 underline"
                                        >resource guides</a
                                    >—many common questions are answered there!
                                </p>
                            </div>
                        </div>
                    </GlassCard>

                    <!-- FAQ Preview -->
                    <div class="glass-panel rounded-2xl p-6 md:p-8">
                        <h3
                            class="font-bold text-gray-900 text-base md:text-lg mb-4"
                        >
                            Frequently Asked
                        </h3>
                        <div class="space-y-3">
                            <details class="group">
                                <summary
                                    class="flex items-center justify-between cursor-pointer text-sm md:text-base text-gray-700 font-medium"
                                >
                                    How do I get started with my daycare?
                                    <span
                                        class="text-teal-600 group-open:rotate-180 transition-transform"
                                        >▼</span
                                    >
                                </summary>
                                <p
                                    class="mt-2 text-xs md:text-sm text-gray-600 pl-0"
                                >
                                    Check out our
                                    <a
                                        href="/steps-to-opening-a-daycare"
                                        class="text-teal-600 hover:underline"
                                        >step-by-step guide</a
                                    >
                                    that covers everything from licensing to launch.
                                </p>
                            </details>
                            <details class="group">
                                <summary
                                    class="flex items-center justify-between cursor-pointer text-sm md:text-base text-gray-700 font-medium"
                                >
                                    Are your tools really free?
                                    <span
                                        class="text-teal-600 group-open:rotate-180 transition-transform"
                                        >▼</span
                                    >
                                </summary>
                                <p
                                    class="mt-2 text-xs md:text-sm text-gray-600 pl-0"
                                >
                                    Yes! Our revenue calculator and many
                                    resources are completely free. We also offer
                                    premium resources for those ready to level
                                    up.
                                </p>
                            </details>
                            <details class="group">
                                <summary
                                    class="flex items-center justify-between cursor-pointer text-sm md:text-base text-gray-700 font-medium"
                                >
                                    Do you offer consulting?
                                    <span
                                        class="text-teal-600 group-open:rotate-180 transition-transform"
                                        >▼</span
                                    >
                                </summary>
                                <p
                                    class="mt-2 text-xs md:text-sm text-gray-600 pl-0"
                                >
                                    We offer resources and toolkits for
                                    established daycare owners. Check out our
                                    <a
                                        href="/consulting"
                                        class="text-teal-600 hover:underline"
                                        >Growth Toolkit</a
                                    >
                                    for more.
                                </p>
                            </details>
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </section>
</Layout>

<script>
    // Simple form handling with success message
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const successMessage = document.getElementById("success-message");

    if (form && successMessage) {
        form.addEventListener("submit", (e) => {
            e.preventDefault();

            // In a real implementation, you would send this to your backend
            // For now, just show the success message
            form.classList.add("hidden");
            successMessage.classList.remove("hidden");

            // Reset form after delay (in case user wants to send another message)
            setTimeout(() => {
                form.reset();
            }, 1000);
        });
    }
</script>
