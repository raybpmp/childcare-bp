---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import HeroImage from "../components/ui/HeroImage.astro";
import GlassCard from "../components/ui/GlassCard.astro";
import CtaButton from "../components/CtaButton";
import EmailCaptureModal from "../components/EmailCaptureModal";
---

<Layout title="Daycare Owner Growth Toolkit | ChildcareBusinessPlan.com">
	<!-- Hero Section -->
	<section class="pt-8 pb-12 md:pt-12 md:pb-20">
		<Container size="lg">
			<HeroImage
				src="/images/dashboard-hero.webp"
				alt="Consultant reviewing performance data to develop new marketing ideas for daycare centers"
				className="mb-8 md:mb-12"
			/>
			<div
				class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-12 text-center mb-8 md:mb-12"
			>
				<span
					class="inline-block px-3 py-1 md:px-4 rounded-full bg-purple-100 text-purple-700 text-xs md:text-sm font-semibold mb-4 md:mb-6"
				>
					For Daycare Owners
				</span>
				<h1
					class="text-2xl md:text-5xl font-bold text-gray-900 mb-4 md:mb-6"
				>
					Get the Free Daycare<br />
					<span
						class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-800"
						>Owner Growth Toolkit</span
					>
				</h1>
				<p
					class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto mb-6 md:mb-8"
				>
					Enrollment forecasting, staff retention strategies, and
					systems checklists. Fix what's broken and scale what's
					working.
				</p>
				<CtaButton client:load funnel="consulting" size="lg">
					Unlock My Growth Toolkit
				</CtaButton>
			</div>
		</Container>
	</section>

	<!-- What's Included Section -->
	<section class="py-8 md:py-16">
		<Container size="lg">
			<h2
				class="text-xl md:text-3xl font-bold text-gray-900 mb-6 md:mb-8 text-center"
			>
				What's Inside
			</h2>
			<div
				class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-8 md:mb-12"
			>
				<GlassCard>
					<h3
						class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
					>
						📈 Enrollment Forecast Model
					</h3>
					<p class="text-sm md:text-base text-gray-600 mb-3 md:mb-4">
						Project your capacity, waitlist, and revenue 12 months
						out.
					</p>
					<ul
						class="space-y-1 md:space-y-2 text-xs md:text-sm text-gray-600"
					>
						<li>✓ Seasonal trends</li>
						<li>✓ Marketing ROI</li>
						<li>✓ Pricing scenarios</li>
					</ul>
				</GlassCard>

				<GlassCard>
					<h3
						class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
					>
						👥 Staffing Cost Estimator
					</h3>
					<p class="text-sm md:text-base text-gray-600 mb-3 md:mb-4">
						Calculate true cost of turnover and optimize your team.
					</p>
					<ul
						class="space-y-1 md:space-y-2 text-xs md:text-sm text-gray-600"
					>
						<li>✓ Turnover impact</li>
						<li>✓ Retention strategies</li>
						<li>✓ Benefits benchmarks</li>
					</ul>
				</GlassCard>

				<GlassCard>
					<h3
						class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
					>
						🎯 Marketing Checklist
					</h3>
					<p class="text-sm md:text-base text-gray-600">
						Fill your waitlist without expensive ads.
					</p>
				</GlassCard>

				<GlassCard>
					<h3
						class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
					>
						⚙️ Systems & Apps Guide
					</h3>
					<p class="text-sm md:text-base text-gray-600">
						Tech stack to automate billing, attendance, and
						communication.
					</p>
				</GlassCard>
			</div>
		</Container>
	</section>

	<!-- CTA Section -->
	<section class="py-12 md:py-20">
		<Container size="md">
			<div
				class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10 text-center border-2 border-purple-200/50 bg-gradient-to-br from-purple-50/50 to-white/50"
			>
				<h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-4">
					Ready to Grow?
				</h3>
				<CtaButton client:load funnel="consulting" size="lg">
					Get the Toolkit Now
				</CtaButton>
			</div>
		</Container>
	</section>

	<EmailCaptureModal client:load />
</Layout>
