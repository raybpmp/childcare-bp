---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import HeroImage from "../components/ui/HeroImage.astro";
import GlassCard from "../components/ui/GlassCard.astro";
---

<Layout
    title="About Us | ChildcareBusinessPlan.com"
    description="Learn about ChildcareBusinessPlan.com - your trusted partner in building successful childcare businesses. We help daycare owners turn their passion into profitable ventures."
>
    <!-- Hero Section -->
    <section class="pt-8 pb-12 md:pt-12 md:pb-20">
        <Container size="lg">
            <HeroImage
                src="/images/company/about.webp"
                alt="Childcare Business Plan Team and Professional B2B Brand Identity"
                className="mb-8 md:mb-12"
            />
            <div
                class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-12 text-center mb-8 md:mb-12"
            >
                <span
                    class="inline-block px-3 py-1 md:px-4 rounded-full bg-teal-100 text-teal-700 text-xs md:text-sm font-semibold mb-4 md:mb-6"
                >
                    Our Story
                </span>
                <h1
                    class="text-2xl md:text-5xl font-bold text-gray-900 mb-4 md:mb-6"
                >
                    Empowering Childcare<br />
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-teal-500 to-teal-700"
                        >Entrepreneurs</span
                    >
                </h1>
                <p class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto">
                    We believe every childcare provider deserves the tools and
                    guidance to build a thriving business while making a real
                    difference in children's lives.
                </p>
            </div>
        </Container>
    </section>

    <!-- Mission Section -->
    <section class="py-8 md:py-16">
        <Container size="lg">
            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 items-center"
            >
                <div>
                    <h2
                        class="text-xl md:text-3xl font-bold text-gray-900 mb-4 md:mb-6"
                    >
                        Our Mission
                    </h2>
                    <p class="text-sm md:text-base text-gray-600 mb-4">
                        Childcare Business Plan was developed by the team at <strong
                            >New Day Partners, Inc.</strong
                        > to solve the complexity of daycare startups. As a specialized
                        branch of New Day Partners, Inc., we leverage our infrastructure
                        to provide world-class business planning services.
                    </p>
                    <p class="text-sm md:text-base text-gray-600 mb-4">
                        Starting and running a childcare business shouldn't feel
                        overwhelming. Whether you're opening your first home
                        daycare or scaling a multi-location center, we provide
                        the roadmaps, tools, and resources to help you succeed.
                    </p>
                    <p class="text-sm md:text-base text-gray-600">
                        Our mission is simple: <strong
                            >turn passionate childcare providers into confident
                            business owners</strong
                        >. We've helped hundreds of daycare entrepreneurs
                        navigate licensing, create solid business plans,
                        optimize pricing, and build sustainable operations.
                    </p>
                </div>
                <div class="glass-panel rounded-2xl p-6 md:p-8">
                    <div class="space-y-4">
                        <div class="flex items-start gap-4">
                            <div
                                class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-teal-400 to-teal-600 rounded-xl flex items-center justify-center text-white text-lg md:text-xl flex-shrink-0"
                            >
                                ✓
                            </div>
                            <div>
                                <h3
                                    class="font-semibold text-gray-900 text-sm md:text-base"
                                >
                                    Evidence-Based Strategies
                                </h3>
                                <p class="text-xs md:text-sm text-gray-600">
                                    Our resources are built on real-world data
                                    and proven business principles.
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div
                                class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-teal-400 to-teal-600 rounded-xl flex items-center justify-center text-white text-lg md:text-xl flex-shrink-0"
                            >
                                ✓
                            </div>
                            <div>
                                <h3
                                    class="font-semibold text-gray-900 text-sm md:text-base"
                                >
                                    Designed for Childcare
                                </h3>
                                <p class="text-xs md:text-sm text-gray-600">
                                    Not generic business advice—everything is
                                    tailored specifically for daycare and
                                    childcare operations.
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div
                                class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-teal-400 to-teal-600 rounded-xl flex items-center justify-center text-white text-lg md:text-xl flex-shrink-0"
                            >
                                ✓
                            </div>
                            <div>
                                <h3
                                    class="font-semibold text-gray-900 text-sm md:text-base"
                                >
                                    Actionable Tools
                                </h3>
                                <p class="text-xs md:text-sm text-gray-600">
                                    From revenue calculators to business plan
                                    templates, our tools save you time and
                                    guesswork.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </section>

    <!-- Values Section -->
    <section class="py-8 md:py-16">
        <Container size="lg">
            <h2
                class="text-xl md:text-3xl font-bold text-gray-900 mb-6 md:mb-8 text-center"
            >
                What We Stand For
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
                <GlassCard>
                    <div
                        class="w-12 h-12 md:w-14 md:h-14 bg-gradient-to-br from-amber-400 to-orange-500 rounded-2xl flex items-center justify-center text-white text-xl md:text-2xl mb-4"
                    >
                        🌱
                    </div>
                    <h3
                        class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
                    >
                        Growth Mindset
                    </h3>
                    <p class="text-sm md:text-base text-gray-600">
                        We believe in continuous learning and improvement. Your
                        childcare business can always evolve and get better.
                    </p>
                </GlassCard>

                <GlassCard>
                    <div
                        class="w-12 h-12 md:w-14 md:h-14 bg-gradient-to-br from-rose-400 to-pink-500 rounded-2xl flex items-center justify-center text-white text-xl md:text-2xl mb-4"
                    >
                        ❤️
                    </div>
                    <h3
                        class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
                    >
                        Passion First
                    </h3>
                    <p class="text-sm md:text-base text-gray-600">
                        You started this journey because you love working with
                        children. We help you build a business that never loses
                        that heart.
                    </p>
                </GlassCard>

                <GlassCard>
                    <div
                        class="w-12 h-12 md:w-14 md:h-14 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-2xl flex items-center justify-center text-white text-xl md:text-2xl mb-4"
                    >
                        🤝
                    </div>
                    <h3
                        class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
                    >
                        Community Focused
                    </h3>
                    <p class="text-sm md:text-base text-gray-600">
                        Childcare providers are the backbone of communities. We
                        support you in supporting families.
                    </p>
                </GlassCard>
            </div>
        </Container>
    </section>

    <!-- CTA Section -->
    <section class="py-12 md:py-20">
        <Container size="md">
            <div
                class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10 text-center border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/50 to-white/50"
            >
                <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">
                    Ready to Build Your Childcare Business?
                </h3>
                <p class="text-sm md:text-base text-gray-600 mb-6">
                    Explore our free tools and resources to get started today.
                </p>
                <a
                    href="/"
                    class="inline-flex items-center justify-center rounded-full bg-teal-600 hover:bg-teal-700 text-white text-sm md:text-base font-medium px-6 py-3 shadow-lg shadow-teal-600/20 transition-all hover:shadow-xl hover:shadow-teal-600/30"
                >
                    Explore Free Tools
                </a>
            </div>
        </Container>
    </section>
</Layout>
