---
import Layout from "@/layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import BlogCard from "@/components/blog/BlogCard.astro";
import { getAllAuthors } from "@/lib/authors";
import { getPostsByAuthor } from "@/lib/blog";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
    const authors = getAllAuthors();
    return authors.map((author) => ({
        params: { slug: author.slug },
        props: { author },
    }));
}) satisfies GetStaticPaths;

const { author } = Astro.props;
const posts = await getPostsByAuthor(author.slug);
---

<Layout title={`${author.name} | Author`} description={author.bio}>
    <section class="py-8 md:py-16">
        <Container size="lg">
            <!-- Back link -->
            <a
                href="/blog"
                class="inline-flex items-center gap-2 text-teal-600 font-semibold mb-6 text-sm md:text-base min-h-[44px]"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                Blog
            </a>

            <!-- Author Hero -->
            <div class="glass-panel rounded-2xl p-6 md:p-10 mb-8">
                <div
                    class="flex flex-col md:flex-row items-center md:items-start gap-6"
                >
                    <img
                        src={author.avatar}
                        alt={author.name}
                        class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover"
                    />
                    <div class="flex-1 text-center md:text-left">
                        <span
                            class="inline-block px-3 py-1.5 rounded-full bg-teal-100 text-teal-700 text-xs font-semibold mb-2"
                        >
                            Author
                        </span>
                        <h1
                            class="text-2xl md:text-3xl font-bold text-gray-900 mb-2"
                        >
                            {author.name}
                        </h1>
                        <p class="text-sm md:text-base text-gray-600 mb-2">
                            {author.role}
                        </p>
                        <p class="text-sm md:text-base text-gray-600">
                            {author.bio}
                        </p>

                        {
                            author.social && (
                                <div class="flex gap-3 mt-4 justify-center md:justify-start">
                                    {author.social.linkedin && (
                                        <a
                                            href={author.social.linkedin}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="px-4 py-2 rounded-full bg-blue-600 text-white hover:bg-blue-700 text-sm md:text-base font-semibold min-h-[44px]"
                                        >
                                            LinkedIn
                                        </a>
                                    )}
                                    {author.social.twitter && (
                                        <a
                                            href={author.social.twitter}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="px-4 py-2 rounded-full bg-sky-500 text-white hover:bg-sky-600 text-sm md:text-base font-semibold min-h-[44px]"
                                        >
                                            Twitter
                                        </a>
                                    )}
                                </div>
                            )
                        }
                    </div>
                </div>
            </div>

            <!-- Posts Header -->
            <div class="mb-6">
                <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-2">
                    Articles by {author.name}
                </h2>
                <p class="text-sm md:text-base text-gray-600">
                    {posts.length}
                    {posts.length === 1 ? "article" : "articles"} published
                </p>
            </div>

            <!-- Posts Grid -->
            <div
                class="space-y-4 md:space-y-0 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-6"
            >
                {posts.map((post) => <BlogCard post={post} />)}
            </div>
        </Container>
    </section>
</Layout>
