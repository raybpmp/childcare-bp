---
interface Props {
    title?: string;
    description?: string;
    buttonText?: string;
    buttonHref?: string;
}

const {
    title = "Ready to See Your Numbers?",
    description = "Find out what you could earn with your own childcare business.",
    buttonText = "Calculate My Income",
    buttonHref = "/#calculator",
} = Astro.props;
---

<div
    class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10 text-center border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/30 to-white/50"
>
    <h2
        class="text-xl md:text-2xl lg:text-3xl font-bold text-gray-900 mb-3 md:mb-4"
    >
        {title}
    </h2>
    <p class="text-base md:text-lg text-gray-600 mb-6 max-w-xl mx-auto">
        {description}
    </p>
    <a
        href={buttonHref}
        class="inline-block bg-teal-600 hover:bg-teal-700 text-white text-base md:text-lg font-semibold px-6 py-4 rounded-full shadow-lg shadow-teal-600/20 transition-all hover:shadow-xl hover:shadow-teal-600/30 hover:-translate-y-0.5 min-h-[48px]"
    >
        {buttonText}
    </a>
</div>
