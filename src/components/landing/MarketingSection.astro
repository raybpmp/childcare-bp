---
import { Container } from "../layout/Container";
import { TrendingUp, ArrowRight } from "lucide-react";
---

<!-- SEO SECTION 3: Marketing & Enrollment -->
<section class="pro-section">
    <Container size="lg">
        <div class="pro-card border-2 border-teal-200/20 bg-gradient-to-br from-teal-50/10 to-transparent">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12 items-center">
                <div>
                    <div class="pro-icon-box bg-gradient-to-br from-teal-400 to-teal-600 mb-3 md:mb-6">
                        <TrendingUp className="w-4 h-4 text-white" />
                    </div>
                    
                    <h2 class="text-xl md:text-3xl font-bold text-gray-900 mb-3 md:mb-4">
                        Maximized Enrollment Strategies
                    </h2>
                    
                    <p class="text-sm md:text-lg text-gray-600 mb-4 md:mb-6 leading-relaxed">
                        A center at 50% capacity and one at 100% are completely different businesses. 
                        Before you plan how to fill seats, you need to know what filling them means for your bottom line.
                    </p>
                    
                    <a href="#calculator" class="inline-flex items-center gap-1.5 text-teal-600 hover:text-teal-700 font-bold text-sm md:text-base group">
                        See your enrollment potential
                        <ArrowRight className="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
                    </a>
                </div>

                <div class="flex justify-center py-4 md:py-0">
                    <div class="relative scale-90 md:scale-100">
                        <div class="w-48 h-48 md:w-64 md:h-64 rounded-full bg-gradient-to-br from-teal-100 to-teal-200 flex items-center justify-center border-4 border-white/50 shadow-inner">
                            <div class="text-center">
                                <div class="text-4xl md:text-5xl font-bold text-teal-600">100%</div>
                                <div class="text-[10px] md:text-sm text-teal-700 font-medium uppercase tracking-wider">Full Enrollment</div>
                            </div>
                        </div>
                        <div class="absolute -bottom-2 -right-2 md:-bottom-4 md:-right-4 w-24 h-24 md:w-32 md:h-32 rounded-full bg-gradient-to-br from-amber-100 to-amber-200 flex items-center justify-center shadow-lg border-2 border-white/80">
                            <div class="text-center">
                                <div class="text-xl md:text-2xl font-bold text-amber-600">50%</div>
                                <div class="text-[10px] text-amber-700 font-medium lowercase">Partial</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>
