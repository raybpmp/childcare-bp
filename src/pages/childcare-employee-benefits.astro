---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
---

<Layout
    title="Childcare Employee Benefits | Childcare Business Plan"
    description="Learn how offering the right employee benefits can improve retention and ROI for your childcare business."
>
    <!-- HERO SECTION -->
    <section class="py-12 md:py-20">
        <Container size="md">
            <div class="text-center mb-8 md:mb-12">
                <span
                    class="inline-block px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-xs font-semibold mb-3"
                >
                    Team Building
                </span>
                <h1
                    class="text-2xl md:text-5xl font-bold text-gray-900 mb-4 md:mb-6"
                >
                    YOUR Employee Retention
                </h1>
                <p class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto">
                    Building a loyal team isn't just about luck—it's about
                    creating an environment where staff feel valued and secure
                    through strategic benefits.
                </p>
            </div>
        </Container>
    </section>

    <!-- FACTORS SECTION -->
    <section class="py-8 md:py-16">
        <Container size="md">
            <div
                class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10 mb-6 md:mb-8"
            >
                <h2
                    class="text-xl md:text-2xl font-bold text-gray-900 mb-4 md:mb-6"
                >
                    What Affects Your Retention ROI
                </h2>
                <div
                    class="space-y-4 text-sm md:text-base text-gray-600 leading-relaxed"
                >
                    <p>
                        The return on investment for employee benefits varies
                        widely based on your local market rates, the specific
                        mix of benefits you offer, and the long-term cost of
                        turnover in your area.
                    </p>
                    <p>
                        Every center's financial capacity and staff demographics
                        create a unique landscape for what works best. What
                        attracts teachers in one market may not work in another.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- WHY GENERIC FAILS SECTION -->
    <section class="py-8 md:py-16">
        <Container size="md">
            <div class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10">
                <h2
                    class="text-xl md:text-2xl font-bold text-gray-900 mb-4 md:mb-6"
                >
                    Why Online Advice Often Conflicts
                </h2>
                <div
                    class="space-y-4 text-sm md:text-base text-gray-600 leading-relaxed"
                >
                    <p>
                        Generic articles often suggest expensive packages that
                        don't match the reality of a small to mid-sized
                        childcare business.
                    </p>
                    <p>
                        Your strategy needs to be tailored to your specific
                        budget and the actual needs of your team, not a
                        one-size-fits-all corporate playbook.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- CTA SECTION -->
    <section class="py-12 md:py-20">
        <Container size="md">
            <div
                class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10 text-center border-2 border-purple-200/50 bg-gradient-to-br from-purple-50/50 to-white/50"
            >
                <h2
                    class="text-xl md:text-2xl font-bold text-gray-900 mb-3 md:mb-4"
                >
                    See How Much YOU Could Make in Your State
                </h2>
                <p class="text-sm md:text-base text-gray-600 mb-4 md:mb-6">
                    Get your personalized income estimate to see what budget you
                    have for benefits.
                </p>
                <a
                    href="/#calculator"
                    class="inline-flex items-center justify-center rounded-full bg-purple-600 hover:bg-purple-700 text-white font-medium px-6 py-3 md:px-8 md:py-4 shadow-lg transition-all text-sm md:text-base"
                >
                    Use the Free Calculator →
                </a>
            </div>
        </Container>
    </section>
</Layout>
