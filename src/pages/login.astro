---
import Layout from '@/layouts/Layout.astro';
import { Container } from '@/components/layout/Container';
import { LoginForm } from '@/components/auth/LoginForm';
---

<Layout 
    title="Login to Portal | Childcare Business Plan"
    description="Access your dashboard and tools to manage your childcare business."
>
    <div class="relative py-24 min-h-[80vh] flex items-center justify-center">
        <!-- Background decoration -->
        <div class="absolute inset-0 bg-gradient-to-br from-teal-50 to-indigo-50/30 -z-10"></div>
        <div class="absolute right-0 top-0 w-1/3 h-1/2 bg-teal-100/50 rounded-full blur-[100px] -z-10 mix-blend-multiply opacity-70"></div>
        <div class="absolute left-0 bottom-0 w-1/3 h-1/2 bg-indigo-100/50 rounded-full blur-[100px] -z-10 mix-blend-multiply opacity-70"></div>

        <Container size="md" className="relative z-10 w-full">
            <LoginForm client:load />
        </Container>
    </div>
</Layout>
