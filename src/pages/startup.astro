---
import Layout from '../layouts/Layout.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import CtaButton from '../components/CtaButton';
import EmailCaptureModal from '../components/EmailCaptureModal';
import MetricChip from '../components/ui/MetricChip.astro';
---

<Layout title="Daycare Startup Toolkit | ChildcareBusinessPlan.com">
	<main class="min-h-screen p-4 md:p-8">
		<div class="max-w-6xl mx-auto">
			<!-- Hero -->
			<div class="glass-panel rounded-3xl p-12 text-center mb-12">
				<span class="inline-block px-4 py-1 bg-brand-100 text-brand-700 rounded-full text-sm font-semibold mb-6">For Startup Founders</span>
				<h1 class="text-5xl font-bold text-gray-900 mb-6">
					Get the Free Daycare<br/>
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-teal-800">Startup Toolkit</span>
				</h1>
				<p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">
					Financial calculator, licensing checklist, and 90-day launch roadmap. Everything you need to go from idea to open.
				</p>
				<CtaButton client:load funnel="startup" size="lg">
					Unlock My Startup Toolkit
				</CtaButton>
			</div>

			<!-- What's Included -->
			<h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">What's Inside</h2>
			<div class="grid md:grid-cols-2 gap-6 mb-12">
				<GlassCard>
					<h3 class="text-xl font-bold text-gray-900 mb-3">📊 Startup Cost Calculator</h3>
					<p class="text-gray-600 mb-4">Estimate your total investment, break-even timeline, and monthly operating costs.</p>
					<ul class="space-y-2 text-sm text-gray-600">
						<li>✓ Licensing & permits</li>
						<li>✓ Facility build-out</li>
						<li>✓ Staff & payroll</li>
					</ul>
				</GlassCard>

				<GlassCard>
					<h3 class="text-xl font-bold text-gray-900 mb-3">📋 90-Day Launch Checklist</h3>
					<p class="text-gray-600 mb-4">Step-by-step roadmap from concept to opening day.</p>
					<ul class="space-y-2 text-sm text-gray-600">
						<li>✓ Legal formation</li>
						<li>✓ State licensing</li>
						<li>✓ Marketing & enrollment</li>
					</ul>
				</GlassCard>

				<GlassCard>
					<h3 class="text-xl font-bold text-gray-900 mb-3">👶 Staffing Ratio Planner</h3>
					<p class="text-gray-600 mb-4">Calculate teacher-to-child ratios for your state.</p>
				</GlassCard>

				<GlassCard>
					<h3 class="text-xl font-bold text-gray-900 mb-3">📄 Business Plan Template</h3>
					<p class="text-gray-600 mb-4">Bank-ready template to secure funding.</p>
				</GlassCard>
			</div>

			<!-- CTA -->
			<div class="glass-panel rounded-2xl p-8 text-center">
				<h3 class="text-2xl font-bold text-gray-900 mb-4">Ready to Start?</h3>
				<CtaButton client:load funnel="startup" size="lg">
					Get the Toolkit Now
				</CtaButton>
			</div>
		</div>

		<EmailCaptureModal client:load />
	</main>
</Layout>
