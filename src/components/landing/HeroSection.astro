---
import { Container } from "../layout/Container";
import { Star, ArrowRight } from "lucide-react";
---

<!-- HERO SECTION - ULTRA DENSITY REFACTOR -->
<section class="pro-section bg-white/30">
    <Container size="lg">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8 items-center">
            <!-- Image Column -->
            <div class="md:order-2">
                <div class="relative aspect-[4/3] md:aspect-square max-h-[350px] md:max-h-[450px] mx-auto rounded-xl md:rounded-2xl overflow-hidden shadow-lg border border-white/40">
                    <img
                        src="/hero2.webp"
                        alt="Junya Herron, childcare expert"
                        class="h-full w-full object-cover object-top"
                        loading="eager"
                    />
                    
                    <!-- Co-founder badge -->
                    <div class="absolute bottom-2 right-2 bg-black/60 backdrop-blur-md text-white text-[10px] md:text-xs font-semibold px-2 py-1 rounded-full border border-white/10">
                        Junya Herron – CEO & President
                    </div>
                </div>
            </div>

            <!-- Content Column -->
            <div class="md:order-1 flex flex-col justify-center">
                <div class="inline-flex items-center gap-1.5 mb-2 md:mb-4 px-2 py-1 rounded-full bg-amber-50 w-fit border border-amber-100/50">
                    <Star className="w-3 h-3 fill-amber-500 text-amber-500" />
                    <span class="text-[10px] md:text-xs font-bold text-amber-700 uppercase tracking-tight">Trusted by 1,500+ providers</span>
                </div>

                <h1 class="text-xl md:text-4xl font-black leading-tight text-gray-900 mb-2 md:mb-4 tracking-tighter">
                    The Complete Daycare<br />
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-600 to-teal-500">
                        Business Plan & Startup Guide
                    </span>
                </h1>

                <p class="text-sm md:text-base text-gray-600 leading-relaxed max-w-xl mb-4 md:mb-6 font-medium">
                    You've been thinking about this for a while. Let's find out if the numbers work—together. We build the roadmap, you build the future.
                </p>

                <div class="flex flex-col sm:flex-row gap-2 md:gap-3">
                    <a
                        href="#calculator"
                        class="inline-flex items-center justify-center gap-2 bg-teal-600 hover:bg-teal-700 text-white text-sm md:text-base font-bold py-2.5 px-6 rounded-lg shadow-md shadow-teal-600/20 transition-all hover:-translate-y-0.5 active:scale-95"
                    >
                        See What's Possible
                        <ArrowRight className="w-4 h-4" />
                    </a>
                </div>
            </div>
        </div>
    </Container>
</section>
