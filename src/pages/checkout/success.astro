---
import Layout from "../../layouts/Layout.astro";
import { Container } from "../../components/layout/Container";

// Get session_id from URL
const sessionId = Astro.url.searchParams.get("session_id");
---

<Layout
    title="Payment Successful | Childcare Business Plan"
    description="Thank you for your purchase. Welcome to the Childcare Business Plan community!"
>
    <Container size="md">
        <section class="py-20 text-center">
            <div class="glass-panel rounded-2xl p-8 md:p-12 max-w-xl mx-auto">
                <!-- Success Icon -->
                <div
                    class="w-20 h-20 mx-auto mb-6 rounded-full bg-green-100 flex items-center justify-center"
                >
                    <svg
                        class="w-10 h-10 text-green-600"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>

                <h1 class="text-2xl font-bold text-gray-900 mb-4 md:text-3xl">
                    Welcome to the Family! 🎉
                </h1>

                <p class="text-base text-gray-600 mb-8 md:text-lg">
                    Your payment was successful. You're now part of the
                    Childcare Business Plan community. Check your email for
                    login details and next steps.
                </p>

                <div class="space-y-4">
                    <a
                        href="/portal"
                        class="block w-full py-3 px-6 bg-teal-600 hover:bg-teal-700 text-white font-semibold rounded-lg transition-colors"
                    >
                        Go to Member Portal
                    </a>
                    <a
                        href="/"
                        class="block w-full py-3 px-6 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-lg transition-colors"
                    >
                        Back to Homepage
                    </a>
                </div>

                {
                    sessionId && (
                        <p class="mt-6 text-xs text-gray-400">
                            Order ID: {sessionId}
                        </p>
                    )
                }
            </div>
        </section>
    </Container>
</Layout>
