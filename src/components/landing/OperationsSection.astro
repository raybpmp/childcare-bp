---
import { Container } from "../layout/Container";
import { Heart, ShieldCheck, ArrowRight } from "lucide-react";

const principles = [
    {
        title: "The Right Team",
        description: "Teachers who share your vision. Benefits that keep them.",
        icon: Heart,
        color: "from-rose-400 to-rose-600"
    },
    {
        title: "Sustainable Growth",
        description: "A plan that works today and scales tomorrow.",
        icon: ShieldCheck,
        color: "from-blue-400 to-blue-600"
    }
];
---

<!-- SEO SECTION 4: Operations & Staffing -->
<section class="pro-section bg-white/50">
    <Container size="lg">
        <div class="text-center mb-6">
            <span class="pro-text-meta mb-2 block">The Foundation</span>
            <h2 class="text-xl md:text-3xl font-bold text-gray-900 mb-2">
                Operations, Staffing & Benefits
            </h2>
            <p class="text-sm md:text-base text-gray-600 max-w-2xl mx-auto leading-relaxed">
                Your team is everything. But you can't plan your team until you know what you can sustain financially.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-6 max-w-4xl mx-auto mb-6">
            {principles.map((p) => (
                <div class="pro-card flex items-start gap-4 group hover:border-blue-200 transition-colors">
                    <div class={`pro-icon-box shrink-0 bg-gradient-to-br ${p.color} shadow-sm group-hover:scale-110 transition-transform`}>
                        <p.icon className="w-4 h-4 text-white" />
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900 text-sm md:text-lg mb-1">{p.title}</h3>
                        <p class="text-xs md:text-sm text-gray-600 leading-relaxed">{p.description}</p>
                    </div>
                </div>
            ))}
        </div>

        <div class="pro-card text-center border-2 border-purple-200/30 bg-gradient-to-br from-purple-50/20 to-white/50 max-w-2xl mx-auto">
            <p class="text-sm md:text-lg text-gray-700 mb-3">
                It all starts with knowing what you can build.
            </p>
            <a href="#calculator" class="inline-flex items-center gap-1.5 text-purple-600 hover:text-purple-700 font-bold text-sm md:text-base group">
                Let's figure that out together
                <ArrowRight className="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
            </a>
        </div>
    </Container>
</section>
