---
import { Container } from "../layout/Container";
---

<!-- SEO SECTION 3: Marketing & Enrollment -->
<section class="py-12 md:py-20">
    <Container size="lg">
        <div
            class="glass-panel rounded-2xl p-6 md:rounded-3xl md:p-12 border-2 border-teal-200/30"
        >
            <!-- Mobile: Text only -->
            <div class="md:hidden">
                <div class="flex gap-3 mb-4">
                    <div
                        class="w-12 h-12 rounded-xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center shadow-md flex-shrink-0"
                    >
                        <svg
                            class="w-6 h-6 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                            ></path>
                        </svg>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-900">
                        Daycare Marketing Strategies to Maximize Enrollment
                    </h2>
                </div>
                <p class="text-base text-gray-600 mb-6">
                    A center at 50% capacity and one at 100% are completely
                    different businesses. Know what filling them means for your
                    bottom line.
                </p>
                <a
                    href="#calculator"
                    class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold text-base group"
                >
                    See your enrollment potential
                    <svg
                        class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
                    </svg>
                </a>
            </div>

            <!-- Desktop: Side-by-side with graphic -->
            <div class="hidden md:grid grid-cols-2 gap-8 items-center">
                <div>
                    <div class="flex gap-4 mb-6">
                        <div
                            class="w-20 h-20 rounded-2xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center shadow-lg"
                        >
                            <svg
                                class="w-10 h-10 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                                ></path>
                            </svg>
                        </div>
                    </div>
                    <h2 class="text-4xl font-bold text-gray-900 mb-4">
                        Daycare Marketing Strategies to Maximize Enrollment
                    </h2>
                    <p class="text-lg text-gray-600 mb-6">
                        A center at 50% capacity and one at 100% are completely
                        different businesses. Before you plan how to fill seats,
                        you need to know what filling them means for your bottom
                        line.
                    </p>
                    <a
                        href="#calculator"
                        class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold text-lg group"
                    >
                        See your enrollment potential
                        <svg
                            class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
                        </svg>
                    </a>
                </div>
                <div class="flex justify-center">
                    <div class="relative">
                        <div
                            class="w-64 h-64 rounded-full bg-gradient-to-br from-teal-100 to-teal-200 flex items-center justify-center"
                        >
                            <div class="text-center">
                                <div class="text-5xl font-bold text-teal-600">
                                    100%
                                </div>
                                <div
                                    class="text-base text-teal-700 font-medium"
                                >
                                    Full Enrollment
                                </div>
                            </div>
                        </div>
                        <div
                            class="absolute -bottom-4 -right-4 w-32 h-32 rounded-full bg-gradient-to-br from-amber-100 to-amber-200 flex items-center justify-center shadow-lg"
                        >
                            <div class="text-center">
                                <div class="text-2xl font-bold text-amber-600">
                                    50%
                                </div>
                                <div class="text-xs text-amber-700">
                                    Partial
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>
