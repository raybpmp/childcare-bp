---
import { Container } from "../layout/Container";
---

<!-- SEO SECTION 4: Operations & Staffing -->
<section class="py-12 md:py-20 bg-gradient-to-b from-white/30 to-transparent">
    <Container size="lg">
        <div class="text-center">
            <span
                class="inline-block px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-xs md:text-sm font-semibold mb-3"
            >
                The Foundation
            </span>
            <h2 class="text-2xl md:text-4xl font-bold text-gray-900 mb-4">
                Daycare Operations, Staffing & Benefits
            </h2>
            <p
                class="text-base md:text-xl text-gray-600 max-w-3xl mx-auto mb-8"
            >
                Your team is everything. But you can't plan your team until you
                know what you can sustain.
            </p>

            <!-- Mobile: Inline badges -->
            <div class="flex flex-wrap gap-3 justify-center mb-8 md:hidden">
                <div
                    class="inline-flex items-center gap-2 bg-white/60 rounded-full px-4 py-2 shadow-sm"
                >
                    <div
                        class="w-8 h-8 rounded-full bg-gradient-to-br from-rose-400 to-rose-600 flex items-center justify-center flex-shrink-0"
                    >
                        <svg
                            class="w-4 h-4 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                            ></path>
                        </svg>
                    </div>
                    <span class="text-sm font-semibold text-gray-900"
                        >The Right Team</span
                    >
                </div>
                <div
                    class="inline-flex items-center gap-2 bg-white/60 rounded-full px-4 py-2 shadow-sm"
                >
                    <div
                        class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center flex-shrink-0"
                    >
                        <svg
                            class="w-4 h-4 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                            ></path>
                        </svg>
                    </div>
                    <span class="text-sm font-semibold text-gray-900"
                        >Sustainable Growth</span
                    >
                </div>
            </div>

            <!-- Desktop: Full cards -->
            <div
                class="hidden md:grid grid-cols-2 gap-6 max-w-4xl mx-auto mb-12"
            >
                <div
                    class="glass-panel rounded-3xl p-8 hover:shadow-xl transition-all duration-300"
                >
                    <div
                        class="w-14 h-14 mx-auto mb-4 rounded-full bg-gradient-to-br from-rose-400 to-rose-600 flex items-center justify-center"
                    >
                        <svg
                            class="w-7 h-7 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">
                        The Right Team
                    </h3>
                    <p class="text-gray-600">
                        Teachers who share your vision. Benefits that keep them.
                    </p>
                </div>

                <div
                    class="glass-panel rounded-3xl p-8 hover:shadow-xl transition-all duration-300"
                >
                    <div
                        class="w-14 h-14 mx-auto mb-4 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center"
                    >
                        <svg
                            class="w-7 h-7 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">
                        Sustainable Growth
                    </h3>
                    <p class="text-gray-600">
                        A plan that works today and scales tomorrow.
                    </p>
                </div>
            </div>

            <div
                class="glass-panel rounded-2xl p-6 md:rounded-3xl md:p-10 border-2 border-purple-200/50 bg-gradient-to-br from-purple-50/50 to-white/50 max-w-2xl mx-auto"
            >
                <p class="text-base md:text-xl text-gray-700 mb-4">
                    It all starts with knowing what you can build.
                </p>
                <a
                    href="#calculator"
                    class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-700 font-semibold text-base md:text-lg group"
                >
                    Let's figure that out together
                    <svg
                        class="w-4 h-4 md:w-5 md:h-5 group-hover:translate-x-1 transition-transform"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
                    </svg>
                </a>
            </div>
        </div>
    </Container>
</section>
