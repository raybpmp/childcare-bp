---
import { getAuthor } from "@/lib/authors";
import type { CollectionEntry } from "astro:content";

interface Props {
    post?: CollectionEntry<"posts">;
    author?: ReturnType<typeof getAuthor>;
    size?: "small" | "large";
}

const { post, author: authorProp, size = "small" } = Astro.props;
const author = authorProp || (post && getAuthor(post.data.author));

if (!author) return null;
---

<div
    class={`glass-panel rounded-xl md:rounded-2xl p-4 md:p-6 mb-6 md:mb-8 ${
        size === "large" ? "text-center md:text-left" : "text-center"
    }`}
>
    <div
        class={`flex ${
            size === "large"
                ? "flex-col md:flex-row items-center md:items-start gap-4 md:gap-6"
                : "flex-col items-center gap-3"
        }`}
    >
        <!-- Avatar -->
        <img
            src={author.avatar}
            alt={author.name}
            class={`${
                size === "large" ? "w-20 h-20 md:w-24 md:h-24" : "w-12 h-12"
            } rounded-full object-cover flex-shrink-0`}
        />

        <!-- Info -->
        <div class="flex-1">
            {
                size === "large" && (
                    <span class="inline-block px-3 py-1.5 rounded-full bg-teal-100 text-teal-700 text-sm font-semibold mb-2">
                        Author
                    </span>
                )
            }

            <h3
                class={`${
                    size === "large" ? "text-xl md:text-2xl" : "text-base"
                } font-bold text-gray-900 mb-1`}
            >
                {author.name}
            </h3>

            <p class="text-base text-gray-600 mb-2">
                {author.role}
            </p>

            {
                size === "large" && author.bio && (
                    <p class="text-base text-gray-600 max-w-2xl mb-4">
                        {author.bio}
                    </p>
                )
            }

            <!-- Social Links -->
            {
                size === "large" && author.social && (
                    <div class="flex gap-3 justify-center md:justify-start">
                        {author.social.linkedin && (
                            <a
                                href={author.social.linkedin}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 px-4 py-3 rounded-full bg-blue-600 text-white hover:bg-blue-700 text-base font-semibold transition-colors min-h-[48px]"
                            >
                                LinkedIn
                            </a>
                        )}
                        {author.social.twitter && (
                            <a
                                href={author.social.twitter}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 px-4 py-3 rounded-full bg-sky-500 text-white hover:bg-sky-600 text-base font-semibold transition-colors min-h-[48px]"
                            >
                                Twitter
                            </a>
                        )}
                    </div>
                )
            }
        </div>
    </div>
</div>
