---
import Layout from "@/layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import AuthorCard from "@/components/blog/AuthorCard.astro";
import BlogCTA from "@/components/blog/BlogCTA.astro";
import { getAllPosts, calculateReadTime } from "@/lib/blog";
import type { GetStaticPaths } from "astro";

import { render } from 'astro:content';

export const getStaticPaths = (async () => {
    const posts = await getAllPosts();
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}) satisfies GetStaticPaths;

import GlassParagraph from "@/components/blog/GlassParagraph.astro";

import { getCategoryStyle, getSeoAlt } from "@/config/blog";

const { post } = Astro.props;
const { title, excerpt, coverImage, category, date } = post.data;
const { Content } = await render(post);
const readTime = calculateReadTime(post.body || '');

const cover = coverImage || "/images/blog/default-cover.webp";

const categoryClass = getCategoryStyle(category);

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    image: new URL(
        cover,
        Astro.site || "https://childcarebusinessplan.com",
    ).toString(),
    datePublished: new Date(date).toISOString(),
    author: {
        "@type": "Person",
        name: "Childcare Business Plan Team", // Default, could be extended if author data exists
    },
    articleSection: category,
    description: excerpt,
};
---

<Layout title={`${title} | Blog`} description={excerpt}>
    <section class="pro-section">
        <div class="max-w-xl mx-auto px-4">
            <!-- Back Link -->
            <a
                href="/blog"
                class="inline-flex items-center gap-1.5 text-teal-600 hover:text-teal-700 font-bold mb-3 pro-text-meta uppercase"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                BACK
            </a>

            <!-- Cover Image -->
            <div
                class="aspect-video rounded-xl overflow-hidden mb-4 bg-gray-100"
            >
                <img
                    src={cover}
                    alt={getSeoAlt(title, category || "")}
                    class="w-full h-full object-cover"
                />
            </div>

            <!-- Meta Section -->
            <div class="mb-4">
                {
                    category && (
                        <span
                            class={`inline-block px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-[0.1em] mb-2 ${categoryClass}`}
                        >
                            {category}
                        </span>
                    )
                }
                <h1 class="pro-heading-dense mb-2">
                    {title}
                </h1>
                <div class="flex items-center gap-2 pro-text-meta font-bold">
                    <time datetime={date}>
                        {
                            new Date(date + "T12:00:00").toLocaleDateString("en-US", {
                                month: "short",
                                day: "numeric",
                                year: "numeric",
                            })
                        }
                    </time>
                    <span class="text-teal-200">·</span>
                    <span>{readTime}</span>
                </div>
            </div>

            <!-- Content -->
            <article
                class="pro-prose prose-p:text-sm prose-p:leading-relaxed prose-headings:font-black prose-headings:tracking-tighter prose-a:text-teal-600 prose-img:rounded-xl mb-6"
            >
                <Content components={{ p: GlassParagraph }} />
            </article>

            <div class="mt-8">
                <BlogCTA
                    title="What Could Your Childcare Business Earn?"
                    description="Get personalized income projections based on your state."
                    buttonText="Calculate Income"
                />
            </div>
        </div>
    </section>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>
