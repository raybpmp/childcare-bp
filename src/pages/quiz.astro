---
import Layout from "../layouts/Layout.astro";
import QuizFunnel from "../components/tools/QuizFunnel";
---

<Layout
    title="Discover Your Childcare Revenue Potential | Free Quiz"
    description="Take our free 2-minute quiz to discover how much you could earn running a childcare business in your state. Personalized results based on local market data."
>
    <section class="relative min-h-screen py-24 overflow-hidden">
        <!-- Background gradient -->
        <div
            class="absolute inset-0 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950"
        >
        </div>

        <!-- Decorative elements -->
        <div class="absolute inset-0">
            <div
                class="absolute top-20 right-0 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl"
            >
            </div>
            <div
                class="absolute bottom-20 left-0 w-80 h-80 bg-emerald-500/10 rounded-full blur-3xl"
            >
            </div>
        </div>

        <div class="relative z-10 container mx-auto px-4">
            <!-- Header -->
            <div class="text-center mb-12">
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
                    Discover Your <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-teal-400 to-emerald-400"
                        >Revenue Potential</span
                    >
                </h1>
                <p class="text-gray-400 text-lg max-w-xl mx-auto">
                    Answer a few quick questions to see what you could earn
                    running a childcare business in your state.
                </p>
            </div>

            <!-- Quiz Component -->
            <QuizFunnel client:load />
        </div>
    </section>
</Layout>
