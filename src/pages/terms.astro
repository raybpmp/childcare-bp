---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Service | ChildcareBusinessPlan.com">
	<main class="min-h-screen p-4 md:p-8">
		<div class="max-w-4xl mx-auto">
			<div class="glass-panel rounded-3xl p-12">
				<h1 class="text-4xl font-bold text-gray-900 mb-8">Terms of Service</h1>
				
				<div class="prose prose-gray max-w-none">
					<p class="text-gray-600 mb-6">Last updated: January 2026</p>

					<h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Acceptance of Terms</h2>
					<p class="text-gray-600 mb-4">
						By accessing and using ChildcareBusinessPlan.com, you accept and agree to be bound by these Terms of Service.
					</p>

					<h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Use of Resources</h2>
					<p class="text-gray-600 mb-4">
						The toolkits, templates, and resources provided are for informational purposes only. They do not constitute legal, financial, or professional advice.
					</p>

					<h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Intellectual Property</h2>
					<p class="text-gray-600 mb-4">
						All content, templates, and materials are the property of ChildcareBusinessPlan.com and are protected by copyright laws.
					</p>

					<h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Limitation of Liability</h2>
					<p class="text-gray-600 mb-4">
						We make no guarantees about business outcomes. Users are solely responsible for their business decisions and compliance with local regulations.
					</p>

					<h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Contact</h2>
					<p class="text-gray-600 mb-4">
						For questions, email us at legal@childcarebusinessplan.com
					</p>
				</div>

				<div class="mt-12 pt-8 border-t border-gray-200">
					<a href="/" class="text-brand-600 hover:text-brand-700 font-semibold">← Back to Home</a>
				</div>
			</div>
		</div>
	</main>
</Layout>
