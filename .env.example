# Stripe API Keys
# Get these from https://dashboard.stripe.com/apikeys

# Server-side (secret key - never expose publicly)
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Client-side (publishable key - safe for frontend)
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Stripe Webhook Secret
# Get this from https://dashboard.stripe.com/webhooks after creating a webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Frappe/ERPNext API Configuration
# Portal URL
FRAPPE_URL=https://portal.childcarebusinessplan.com

# API Credentials (from api@childcarebusinessplan.com user)
# Note: Generate API key and secret from User settings in ERPNext
FRAPPE_API_KEY=your_api_key_here
FRAPPE_API_SECRET=your_api_secret_here
