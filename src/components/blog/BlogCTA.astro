---
interface Props {
    title?: string;
    description?: string;
    buttonText?: string;
    buttonHref?: string;
}

const {
    title = "Ready to See Your Numbers?",
    description = "Find out what you could earn with your own childcare business.",
    buttonText = "Calculate My Income",
    buttonHref = "/#calculator",
} = Astro.props;
---

<div class="pro-card glass-panel shadow-sm space-y-3 text-center border-teal-100/50">
    <h2 class="pro-heading-dense">
        {title}
    </h2>
    <p class="pro-text-meta max-w-xs mx-auto">
        {description}
    </p>
    <div class="pt-2">
        <a
            href={buttonHref}
            class="inline-block bg-teal-600 text-white text-xs font-bold px-6 py-2.5 rounded-full shadow-lg shadow-teal-600/20 transition-all hover:opacity-90 min-h-[40px] uppercase tracking-wider"
        >
            {buttonText}
        </a>
    </div>
</div>
