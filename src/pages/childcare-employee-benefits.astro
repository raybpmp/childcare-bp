---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import HeroImage from "../components/ui/HeroImage.astro";
import { ArrowRight } from "lucide-react";
---

<Layout
    title="Childcare Employee Benefits | Childcare Business Plan"
    description="Learn how offering the right employee benefits can improve retention and ROI for your childcare business."
>
    <!-- HERO SECTION -->
    <section class="pro-section">
        <Container size="md">
            <HeroImage
                src="/images/growth/childcare-employee-benefits.webp"
                alt="Professional staff training session demonstrating high-value childcare employee benefits for team retention"
                className="mb-4 md:mb-12"
            />
            <div class="text-center">
                <span class="pro-text-meta mb-2 block text-purple-600">
                    Team Building
                </span>
                <h1 class="text-xl md:text-5xl font-bold text-gray-900 mb-2 md:mb-6">
                    YOUR Employee Retention
                </h1>
                <p class="text-sm md:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
                    Building a loyal team isn't just about luck—it's about creating an environment where staff feel valued and secure through strategic benefits.
                </p>
            </div>
        </Container>
    </section>

    <!-- FACTORS SECTION -->
    <section class="pro-section bg-gray-50/50">
        <Container size="md">
            <div class="pro-card mb-3 md:mb-8">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-6 uppercase tracking-wider">
                    What Affects Your Retention ROI
                </h2>
                <div class="space-y-3 text-xs md:text-base text-gray-600 leading-relaxed font-medium">
                    <p>
                        The return on investment for benefits varies widely based on your local market rates, the specific mix you offer, and the long-term cost of turnover.
                    </p>
                    <p>
                        Every center's financial capacity and staff demographics create a unique landscape. What attracts teachers in one market may not work in another.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- WHY GENERIC FAILS SECTION -->
    <section class="pro-section">
        <Container size="md">
            <div class="pro-card">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-6 uppercase tracking-wider">
                    Why Advice Conflicts
                </h2>
                <div class="space-y-3 text-xs md:text-base text-gray-600 leading-relaxed font-medium">
                    <p>
                        Generic articles often suggest expensive packages that don't match the reality of a small to mid-sized childcare business.
                    </p>
                    <p>
                        Your strategy needs to be tailored to your specific budget and the actual needs of your team, not a corporate playbook.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- CTA SECTION -->
    <section class="pro-section">
        <Container size="md">
            <div class="pro-card text-center border-2 border-purple-200/50 bg-gradient-to-br from-purple-50/20 to-white/50">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-4">
                    See YOUR Budget for Benefits
                </h2>
                <p class="text-xs md:text-base text-gray-600 mb-3 md:mb-6">
                    Get your personalized income estimate to see what budget you have for benefits.
                </p>
                <a
                    href="/#calculator"
                    class="inline-flex items-center gap-1.5 justify-center rounded-full bg-purple-600 hover:bg-purple-700 text-white font-bold px-5 py-2 md:px-8 md:py-4 shadow-lg transition-all text-xs md:text-base group"
                >
                    Use the Free Calculator
                    <ArrowRight className="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" />
                </a>
            </div>
        </Container>
    </section>
</Layout>
