---
import Layout from "../layouts/Layout.astro";
import EmailModal from "../components/EmailModal";
import IncomeBuilderTool from "../components/tools/IncomeBuilderTool";
import { Container } from "../components/layout/Container";
---

<Layout title="Daycare Business Plan & Revenue Calculator | Start Your Center">
	<!-- HERO SECTION -->
	<section class="py-12 md:py-0 md:min-h-[90vh]">
		<Container size="xl">
			<div class="md:grid md:grid-cols-2 md:gap-12 md:items-center">
				<!-- Mobile: Image container with overlaid text -->
				<div class="mb-6 md:mb-0 md:order-2">
					<!-- Image container -->
					<div
						class="relative aspect-[3/4] max-h-[500px] md:max-h-[700px] mx-auto md:rounded-3xl overflow-hidden md:shadow-2xl"
					>
						<img
							src="/hero-woman.webp"
							alt="Childcare professional"
							class="h-full w-full object-cover object-top"
							loading="eager"
						/>

						<!-- Gradient overlay for mobile text readability -->
						<div
							class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent via-50% to-black/70 md:hidden"
						>
						</div>

						<!-- Overlaid text (mobile only - hidden on desktop) -->
						<div
							class="absolute inset-0 flex flex-col justify-between p-6 pt-8 pb-8 md:hidden"
						>
							<div class="space-y-4">
								<!-- Glass panel headline -->
								<div
									class="bg-white/10 rounded-3xl p-6 border border-white/20"
								>
									<h1
										class="text-xl font-bold leading-tight text-center"
									>
										<span class="text-white drop-shadow-lg"
											>The Complete Daycare</span
										><br />
										<span
											class="text-transparent bg-clip-text bg-gradient-to-r from-teal-300 to-teal-100"
										>
											Business Plan & Startup Guide
										</span>
									</h1>
								</div>

								<!-- Subtext -->
								<p
									class="text-base text-white/90 leading-relaxed text-center px-2 drop-shadow-md"
								>
									You've been thinking about this for a while.
									Let's find out if the numbers work—together.
								</p>
							</div>

							<!-- Trust indicator -->
							<div class="flex justify-center">
								<div
									class="bg-black/30 rounded-full px-4 py-2 border border-white/10 inline-flex items-center gap-2"
								>
									<span class="text-amber-400">★★★★★</span>
									<span
										class="text-sm text-white/90 font-medium"
										>Trusted by 1,500+ providers</span
									>
								</div>
							</div>
						</div>

						<!-- Co-founder badge -->
						<div
							class="absolute bottom-3 right-3 md:bottom-4 md:right-4 bg-black/50 backdrop-blur-sm text-white text-xs md:text-sm font-medium px-3 py-1.5 md:px-4 md:py-2 rounded-full"
						>
							Junya Herron – Co-Founder
						</div>
					</div>
				</div>

				<!-- Text content (desktop left column, mobile below image) -->
				<div class="md:order-1">
					<!-- Desktop text (hidden on mobile since it's overlaid on image) -->
					<div class="hidden md:block">
						<h1
							class="text-4xl lg:text-5xl font-bold leading-tight mb-4"
						>
							<span class="text-gray-900">The Complete</span><br
							/>
							<span
								class="text-transparent bg-clip-text bg-gradient-to-r from-teal-500 to-teal-600"
							>
								Daycare Business Plan
							</span><br />
							<span class="text-gray-900">& Startup Guide</span>
						</h1>

						<p class="text-lg text-gray-600 leading-relaxed mb-6">
							You've been thinking about this for a while. Let's
							find out if the numbers work—together.
						</p>

						<div class="flex items-center gap-2 mb-6">
							<span class="text-amber-500">★★★★★</span>
							<span class="text-sm text-gray-700 font-medium"
								>Trusted by 1,500+ providers</span
							>
						</div>
					</div>

					<!-- CTA button (both mobile and desktop) -->
					<a
						href="#calculator"
						class="block md:inline-block w-full md:w-auto bg-gradient-to-r from-teal-500 to-teal-600 md:bg-teal-600 hover:from-teal-600 hover:to-teal-700 md:hover:bg-teal-700 text-white text-center text-lg font-bold md:font-semibold py-4 px-8 rounded-full shadow-xl shadow-teal-500/40 md:shadow-teal-600/30 transition-all md:hover:shadow-2xl md:hover:-translate-y-1"
					>
						See What's Possible for Me
					</a>
				</div>
			</div>
		</Container>
	</section>

	<!-- CALCULATOR SECTION -->
	<section
		id="calculator"
		class="py-12 bg-gradient-to-b from-white/50 to-transparent"
	>
		<Container size="md">
			<div
				class="glass-panel rounded-2xl p-4 md:p-6 text-center mb-4 md:mb-8 border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/50 to-white/50"
			>
				<span
					class="inline-block px-3 py-1 rounded-full bg-teal-100 text-teal-700 text-xs font-semibold mb-2 md:mb-3"
				>
					Revenue Calculator
				</span>
				<h2 class="text-2xl md:text-4xl font-bold mb-2 md:mb-3">
					<span
						class="text-transparent bg-clip-text bg-gradient-to-r from-teal-600 to-teal-500"
					>
						Calculate Your Daycare Revenue
					</span>
				</h2>
				<p class="text-sm md:text-lg text-gray-600 max-w-xl mx-auto">
					Select your state and business type to get started.
				</p>
			</div>
			<IncomeBuilderTool client:load />
		</Container>
	</section>

	<!-- SEO SECTION 1: Steps to Opening -->
	<section class="py-12 md:py-20">
		<Container size="lg">
			<div class="text-center mb-8">
				<span
					class="inline-block px-3 py-1 rounded-full bg-teal-100 text-teal-700 text-xs font-semibold mb-3"
				>
					The Journey
				</span>
				<h2 class="text-2xl md:text-4xl font-bold text-gray-900 mb-3">
					Steps to Opening a Daycare Center
				</h2>
				<p class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto">
					Opening a daycare isn't something you figure out from a blog
					post. The path looks different for everyone.
				</p>
			</div>

			<!-- Mobile: Horizontal scroll -->
			<div
				class="flex gap-4 overflow-x-auto pb-4 md:hidden snap-x snap-mandatory"
			>
				<div class="flex-shrink-0 w-32 snap-start text-center">
					<div
						class="w-14 h-14 mx-auto mb-3 rounded-xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center shadow-md"
					>
						<svg
							class="w-7 h-7 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
							></path>
						</svg>
					</div>
					<h3 class="text-sm font-bold text-gray-900">
						Know Your Numbers
					</h3>
				</div>

				<div class="flex-shrink-0 w-32 snap-start text-center">
					<div
						class="w-14 h-14 mx-auto mb-3 rounded-xl bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center shadow-md"
					>
						<svg
							class="w-7 h-7 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
							></path>
						</svg>
					</div>
					<h3 class="text-sm font-bold text-gray-900">
						State Requirements
					</h3>
				</div>

				<div class="flex-shrink-0 w-32 snap-start text-center">
					<div
						class="w-14 h-14 mx-auto mb-3 rounded-xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-md"
					>
						<svg
							class="w-7 h-7 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
						</svg>
					</div>
					<h3 class="text-sm font-bold text-gray-900">
						Your Unique Path
					</h3>
				</div>
			</div>

			<!-- Desktop: Full grid -->
			<div class="hidden md:grid grid-cols-3 gap-6 mb-12">
				<div
					class="glass-panel rounded-3xl p-8 text-center hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center shadow-lg shadow-teal-500/30"
					>
						<svg
							class="w-8 h-8 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
							></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">
						Know Your Numbers
					</h3>
					<p class="text-gray-600">
						Before the paperwork, before the location hunt—clarity
						on what's possible.
					</p>
				</div>

				<div
					class="glass-panel rounded-3xl p-8 text-center hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center shadow-lg shadow-purple-500/30"
					>
						<svg
							class="w-8 h-8 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
							></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">
						State Requirements
					</h3>
					<p class="text-gray-600">
						Every state has unique rules. Your plan has to fit your
						reality.
					</p>
				</div>

				<div
					class="glass-panel rounded-3xl p-8 text-center hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-lg shadow-amber-500/30"
					>
						<svg
							class="w-8 h-8 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">
						Your Unique Path
					</h3>
					<p class="text-gray-600">
						Generic advice doesn't work. You need a plan built for
						your situation.
					</p>
				</div>
			</div>

			<div
				class="glass-panel rounded-2xl p-6 md:p-10 text-center border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/50 to-white/50"
			>
				<p class="text-base md:text-xl text-gray-700 mb-4">
					The first step isn't paperwork. It's clarity.
				</p>
				<a
					href="#calculator"
					class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold text-base md:text-lg group"
				>
					Let's start with your numbers
					<svg
						class="w-5 h-5 group-hover:translate-x-1 transition-transform"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
					</svg>
				</a>
			</div>
		</Container>
	</section>

	<!-- SEO SECTION 2: Licensing & Costs -->
	<section
		class="py-12 md:py-20 bg-gradient-to-b from-white/30 to-transparent"
	>
		<Container size="lg">
			<!-- Mobile: Stacked layout -->
			<div class="md:hidden">
				<span
					class="inline-block px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-xs font-semibold mb-3"
				>
					The Reality
				</span>
				<h2 class="text-2xl font-bold text-gray-900 mb-4">
					Daycare Licensing Requirements & Start-Up Costs
				</h2>
				<p class="text-base text-gray-600 mb-6">
					Every state has its own rules. You deserve to see what it
					actually looks like for <em>your</em> state, <em>your</em> capacity,
					<em>your</em> vision.
				</p>

				<!-- Compact 2x2 grid -->
				<div class="grid grid-cols-2 gap-3 mb-6">
					<div class="text-center p-3 bg-white/50 rounded-xl">
						<div class="text-2xl mb-1">📍</div>
						<p class="text-xs font-semibold text-gray-900">
							Location
						</p>
					</div>
					<div class="text-center p-3 bg-white/50 rounded-xl">
						<div class="text-2xl mb-1">📋</div>
						<p class="text-xs font-semibold text-gray-900">
							Licensing
						</p>
					</div>
					<div class="text-center p-3 bg-white/50 rounded-xl">
						<div class="text-2xl mb-1">👥</div>
						<p class="text-xs font-semibold text-gray-900">
							Staffing
						</p>
					</div>
					<div class="text-center p-3 bg-white/50 rounded-xl">
						<div class="text-2xl mb-1">💰</div>
						<p class="text-xs font-semibold text-gray-900">
							Investment
						</p>
					</div>
				</div>

				<a
					href="#calculator"
					class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-700 font-semibold text-base group"
				>
					See what's possible for you
					<svg
						class="w-4 h-4 group-hover:translate-x-1 transition-transform"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
					</svg>
				</a>
			</div>

			<!-- Desktop: Side-by-side layout -->
			<div class="hidden md:grid grid-cols-2 gap-12 items-center">
				<div>
					<span
						class="inline-block px-4 py-2 rounded-full bg-purple-100 text-purple-700 text-sm font-semibold mb-4"
					>
						The Reality
					</span>
					<h2 class="text-4xl font-bold text-gray-900 mb-6">
						Daycare Licensing Requirements & Start-Up Costs
					</h2>
					<p class="text-lg text-gray-600 mb-6">
						Every state has its own rules. Costs vary wildly
						depending on where you are and what you're building.
						That's why generic advice feels so confusing—it wasn't
						written for you.
					</p>
					<p class="text-lg text-gray-600 mb-8">
						You deserve to see what it actually looks like for <em
							>your</em
						> state, <em>your</em> capacity, <em>your</em> vision.
					</p>
					<a
						href="#calculator"
						class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-700 font-semibold text-lg group"
					>
						See what's possible for you
						<svg
							class="w-5 h-5 group-hover:translate-x-1 transition-transform"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
						</svg>
					</a>
				</div>

				<div class="grid grid-cols-2 gap-4">
					<div class="glass-panel rounded-2xl p-6 text-center">
						<div class="text-3xl mb-2">📍</div>
						<h4 class="font-bold text-gray-900 mb-1">Location</h4>
						<p class="text-sm text-gray-600">
							Zoning, space, accessibility
						</p>
					</div>
					<div class="glass-panel rounded-2xl p-6 text-center">
						<div class="text-3xl mb-2">📋</div>
						<h4 class="font-bold text-gray-900 mb-1">Licensing</h4>
						<p class="text-sm text-gray-600">
							State-specific requirements
						</p>
					</div>
					<div class="glass-panel rounded-2xl p-6 text-center">
						<div class="text-3xl mb-2">👥</div>
						<h4 class="font-bold text-gray-900 mb-1">Staffing</h4>
						<p class="text-sm text-gray-600">
							Ratios & qualifications
						</p>
					</div>
					<div class="glass-panel rounded-2xl p-6 text-center">
						<div class="text-3xl mb-2">💰</div>
						<h4 class="font-bold text-gray-900 mb-1">Investment</h4>
						<p class="text-sm text-gray-600">
							Startup & operations
						</p>
					</div>
				</div>
			</div>
		</Container>
	</section>

	<!-- SEO SECTION 3: Marketing & Enrollment -->
	<section class="py-12 md:py-20">
		<Container size="lg">
			<div
				class="glass-panel rounded-2xl p-6 md:rounded-3xl md:p-12 border-2 border-teal-200/30"
			>
				<!-- Mobile: Text only -->
				<div class="md:hidden">
					<div class="flex gap-3 mb-4">
						<div
							class="w-12 h-12 rounded-xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center shadow-md flex-shrink-0"
						>
							<svg
								class="w-6 h-6 text-white"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
								></path>
							</svg>
						</div>
						<h2 class="text-2xl font-bold text-gray-900">
							Daycare Marketing Strategies to Maximize Enrollment
						</h2>
					</div>
					<p class="text-base text-gray-600 mb-6">
						A center at 50% capacity and one at 100% are completely
						different businesses. Know what filling them means for
						your bottom line.
					</p>
					<a
						href="#calculator"
						class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold text-base group"
					>
						See your enrollment potential
						<svg
							class="w-4 h-4 group-hover:translate-x-1 transition-transform"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
						</svg>
					</a>
				</div>

				<!-- Desktop: Side-by-side with graphic -->
				<div class="hidden md:grid grid-cols-2 gap-8 items-center">
					<div>
						<div class="flex gap-4 mb-6">
							<div
								class="w-20 h-20 rounded-2xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center shadow-lg"
							>
								<svg
									class="w-10 h-10 text-white"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
									></path>
								</svg>
							</div>
						</div>
						<h2 class="text-4xl font-bold text-gray-900 mb-4">
							Daycare Marketing Strategies to Maximize Enrollment
						</h2>
						<p class="text-lg text-gray-600 mb-6">
							A center at 50% capacity and one at 100% are
							completely different businesses. Before you plan how
							to fill seats, you need to know what filling them
							means for your bottom line.
						</p>
						<a
							href="#calculator"
							class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold text-lg group"
						>
							See your enrollment potential
							<svg
								class="w-5 h-5 group-hover:translate-x-1 transition-transform"
								fill="none"
								stroke="currentColor"
