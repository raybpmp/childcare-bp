---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import HeroImage from "../components/ui/HeroImage.astro";
import GlassCard from "../components/ui/GlassCard.astro";
import CtaButton from "../components/CtaButton";
import EmailCaptureModal from "../components/EmailCaptureModal";
---

<Layout title="Daycare Startup Toolkit | ChildcareBusinessPlan.com">
	<!-- Hero Section -->
	<section class="pt-8 pb-12 md:pt-12 md:pb-20">
		<Container size="lg">
			<HeroImage
				src="/images/company/startup-toolkit.webp"
				alt="Free Daycare Startup Toolkit, Business Plan Template, and Licensing Roadmap"
				className="mb-8 md:mb-12"
			/>
			<div
				class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-12 text-center mb-8 md:mb-12"
			>
				<span
					class="inline-block px-3 py-1 md:px-4 rounded-full bg-teal-100 text-teal-700 text-xs md:text-sm font-semibold mb-4 md:mb-6"
				>
					For Startup Founders
				</span>
				<h1
					class="text-2xl md:text-5xl font-bold text-gray-900 mb-4 md:mb-6"
				>
					Get the Free Daycare<br />
					<span
						class="text-transparent bg-clip-text bg-gradient-to-r from-teal-600 to-teal-800"
						>Startup Toolkit</span
					>
				</h1>
				<p
					class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto mb-6 md:mb-8"
				>
					Financial calculator, licensing checklist, and 90-day launch
					roadmap. Everything you need to go from idea to open.
				</p>
				<CtaButton client:load funnel="startup" size="lg">
					Unlock My Startup Toolkit
				</CtaButton>
			</div>
		</Container>
	</section>

	<!-- What's Included Section -->
	<section class="py-8 md:py-16">
		<Container size="lg">
			<h2
				class="text-xl md:text-3xl font-bold text-gray-900 mb-6 md:mb-8 text-center"
			>
				What's Inside
			</h2>
			<div
				class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-8 md:mb-12"
			>
				<GlassCard>
					<h3
						class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
					>
						📊 Startup Cost Calculator
					</h3>
					<p class="text-sm md:text-base text-gray-600 mb-3 md:mb-4">
						Estimate your total investment, break-even timeline, and
						monthly operating costs.
					</p>
					<ul
						class="space-y-1 md:space-y-2 text-xs md:text-sm text-gray-600"
					>
						<li>✓ Licensing & permits</li>
						<li>✓ Facility build-out</li>
						<li>✓ Staff & payroll</li>
					</ul>
				</GlassCard>

				<GlassCard>
					<h3
						class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
					>
						📋 90-Day Launch Checklist
					</h3>
					<p class="text-sm md:text-base text-gray-600 mb-3 md:mb-4">
						Step-by-step roadmap from concept to opening day.
					</p>
					<ul
						class="space-y-1 md:space-y-2 text-xs md:text-sm text-gray-600"
					>
						<li>✓ Legal formation</li>
						<li>✓ State licensing</li>
						<li>✓ Marketing & enrollment</li>
					</ul>
				</GlassCard>

				<GlassCard>
					<h3
						class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
					>
						👶 Staffing Ratio Planner
					</h3>
					<p class="text-sm md:text-base text-gray-600">
						Calculate teacher-to-child ratios for your state.
					</p>
				</GlassCard>

				<GlassCard>
					<h3
						class="text-lg md:text-xl font-bold text-gray-900 mb-2 md:mb-3"
					>
						📄 Business Plan Template
					</h3>
					<p class="text-sm md:text-base text-gray-600">
						Bank-ready template to secure funding.
					</p>
				</GlassCard>
			</div>
		</Container>
	</section>

	<!-- CTA Section -->
	<section class="py-12 md:py-20">
		<Container size="md">
			<div
				class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10 text-center border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/50 to-white/50"
			>
				<h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-4">
					Ready to Start?
				</h3>
				<CtaButton client:load funnel="startup" size="lg">
					Get the Toolkit Now
				</CtaButton>
			</div>
		</Container>
	</section>

	<EmailCaptureModal client:load />
</Layout>
