---
import Layout from "../layouts/Layout.astro";
import EmailModal from "../components/EmailModal";
import IncomeBuilderTool from "../components/tools/IncomeBuilderTool";
---

<Layout title="Daycare Business Plan & Revenue Calculator | Start Your Center">
	<!-- HERO SECTION -->
	<section class="py-12 md:py-0 md:min-h-[90vh] px-6">
		<div class="max-w-7xl mx-auto">
			<div
				class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center md:min-h-[90vh]"
			>
				<!-- Left Column: Content -->
				<div class="order-2 md:order-1 py-8">
					<h1
						class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 leading-tight text-gray-900"
					>
						The Complete Daycare Business Plan & Startup Guide
					</h1>
					<p class="text-base md:text-lg text-gray-600 mb-8">
						You've been thinking about this for a while. Maybe it's
						been months, maybe years. Let's find out if the numbers
						work—together.
					</p>

					<a
						href="#calculator"
						class="inline-block w-full md:w-auto bg-teal-600 hover:bg-teal-700 text-white text-center text-lg font-semibold px-8 py-4 rounded-full shadow-xl shadow-teal-600/30 transition-all hover:shadow-2xl hover:-translate-y-1"
					>
						See What's Possible for Me
					</a>
				</div>

				<!-- Right Column: Hero Image -->
				<div class="order-1 md:order-2">
					<div
						class="relative aspect-[3/4] md:aspect-[3/4] max-h-[500px] md:max-h-[700px] mx-auto rounded-3xl overflow-hidden shadow-2xl"
					>
						<img
							src="/hero-woman.png"
							alt="Childcare professional"
							class="h-full w-full object-cover object-top"
							loading="eager"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- TRUST BAR -->
	<section
		class="py-4 px-6 bg-white/50 backdrop-blur-sm border-y border-gray-200/50"
	>
		<div
			class="max-w-7xl mx-auto flex items-center justify-center gap-3 text-sm md:text-base text-gray-700"
		>
			<span class="text-amber-500 text-lg">★★★★★</span>
			<span class="font-medium"
				>Trusted by 1,500+ childcare providers</span
			>
		</div>
	</section>

	<!-- CALCULATOR SECTION -->
	<section
		id="calculator"
		class="py-12 px-4 bg-gradient-to-b from-white/50 to-transparent"
	>
		<div class="max-w-3xl mx-auto text-center mb-8">
			<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
				Calculate Your Potential Revenue Before You Write a Single Word
			</h2>
			<p class="text-lg md:text-xl text-gray-600 mb-4">
				Every state is different. Every situation is unique. Before you
				plan anything else, let's see what's actually possible for you.
			</p>
			<p class="text-base md:text-lg text-gray-700 font-medium">
				Select your state and business type to get started.
			</p>
		</div>
		<IncomeBuilderTool client:load />
	</section>

	<!-- SEO SECTION 1: Steps to Opening -->
	<section class="py-16 md:py-24 px-4 md:px-6">
		<div class="max-w-6xl mx-auto">
			<div class="text-center mb-12">
				<span
					class="inline-block px-4 py-2 rounded-full bg-teal-100 text-teal-700 text-sm font-semibold mb-4"
				>
					The Journey
				</span>
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
					Steps to Opening a Daycare Center
				</h2>
				<p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto">
					Opening a daycare isn't something you figure out from a blog
					post. The path looks different for everyone.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
				<div
					class="glass-panel rounded-3xl p-8 text-center hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center shadow-lg shadow-teal-500/30"
					>
						<svg
							class="w-8 h-8 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
							></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">
						Know Your Numbers
					</h3>
					<p class="text-gray-600">
						Before the paperwork, before the location hunt—clarity
						on what's possible.
					</p>
				</div>

				<div
					class="glass-panel rounded-3xl p-8 text-center hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center shadow-lg shadow-purple-500/30"
					>
						<svg
							class="w-8 h-8 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
							></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">
						State Requirements
					</h3>
					<p class="text-gray-600">
						Every state has unique rules. Your plan has to fit your
						reality.
					</p>
				</div>

				<div
					class="glass-panel rounded-3xl p-8 text-center hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
				>
					<div
						class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-lg shadow-amber-500/30"
					>
						<svg
							class="w-8 h-8 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">
						Your Unique Path
					</h3>
					<p class="text-gray-600">
						Generic advice doesn't work. You need a plan built for
						your situation.
					</p>
				</div>
			</div>

			<div
				class="glass-panel rounded-3xl p-8 md:p-10 text-center border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/50 to-white/50"
			>
				<p class="text-lg md:text-xl text-gray-700 mb-6">
					The first step isn't paperwork. It's clarity.
				</p>
				<a
					href="#calculator"
					class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold text-lg group"
				>
					Let's start with your numbers
					<svg
						class="w-5 h-5 group-hover:translate-x-1 transition-transform"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
					</svg>
				</a>
			</div>
		</div>
	</section>

	<!-- SEO SECTION 2: Licensing & Costs -->
	<section
		class="py-16 md:py-24 px-4 md:px-6 bg-gradient-to-b from-white/30 to-transparent"
	>
		<div class="max-w-6xl mx-auto">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<div>
					<span
						class="inline-block px-4 py-2 rounded-full bg-purple-100 text-purple-700 text-sm font-semibold mb-4"
					>
						The Reality
					</span>
					<h2
						class="text-3xl md:text-4xl font-bold text-gray-900 mb-6"
					>
						Licensing Requirements & Start-Up Costs
					</h2>
					<p class="text-lg text-gray-600 mb-6">
						Every state has its own rules. Costs vary wildly
						depending on where you are and what you're building.
						That's why generic advice feels so confusing—it wasn't
						written for you.
					</p>
					<p class="text-lg text-gray-600 mb-8">
						You deserve to see what it actually looks like for <em
							>your</em
						> state, <em>your</em> capacity, <em>your</em> vision.
					</p>
					<a
						href="#calculator"
						class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-700 font-semibold text-lg group"
					>
						See what's possible for you
						<svg
							class="w-5 h-5 group-hover:translate-x-1 transition-transform"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
						</svg>
					</a>
				</div>

				<div class="grid grid-cols-2 gap-4">
					<div class="glass-panel rounded-2xl p-6 text-center">
						<div class="text-3xl mb-2">📍</div>
						<h4 class="font-bold text-gray-900 mb-1">Location</h4>
						<p class="text-sm text-gray-600">
							Zoning, space, accessibility
						</p>
					</div>
					<div class="glass-panel rounded-2xl p-6 text-center">
						<div class="text-3xl mb-2">📋</div>
						<h4 class="font-bold text-gray-900 mb-1">Licensing</h4>
						<p class="text-sm text-gray-600">
							State-specific requirements
						</p>
					</div>
					<div class="glass-panel rounded-2xl p-6 text-center">
						<div class="text-3xl mb-2">👥</div>
						<h4 class="font-bold text-gray-900 mb-1">Staffing</h4>
						<p class="text-sm text-gray-600">
							Ratios & qualifications
						</p>
					</div>
					<div class="glass-panel rounded-2xl p-6 text-center">
						<div class="text-3xl mb-2">💰</div>
						<h4 class="font-bold text-gray-900 mb-1">Investment</h4>
						<p class="text-sm text-gray-600">
							Startup & operations
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- SEO SECTION 3: Marketing & Enrollment -->
	<section class="py-16 md:py-24 px-4 md:px-6">
		<div class="max-w-6xl mx-auto">
			<div
				class="glass-panel rounded-3xl p-8 md:p-12 border-2 border-teal-200/30"
			>
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
					<div class="order-2 lg:order-1">
						<div class="flex gap-4 mb-6">
							<div
								class="w-20 h-20 rounded-2xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center shadow-lg"
							>
								<svg
									class="w-10 h-10 text-white"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
									></path>
								</svg>
							</div>
						</div>
						<h2
							class="text-3xl md:text-4xl font-bold text-gray-900 mb-4"
						>
							Marketing Strategies to Maximize Enrollment
						</h2>
						<p class="text-lg text-gray-600 mb-6">
							A center at 50% capacity and one at 100% are
							completely different businesses. Before you plan how
							to fill seats, you need to know what filling them
							means for your bottom line.
						</p>
						<a
							href="#calculator"
							class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold text-lg group"
						>
							See your enrollment potential
							<svg
								class="w-5 h-5 group-hover:translate-x-1 transition-transform"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
							</svg>
						</a>
					</div>
					<div class="order-1 lg:order-2 flex justify-center">
						<div class="relative">
							<div
								class="w-48 h-48 md:w-64 md:h-64 rounded-full bg-gradient-to-br from-teal-100 to-teal-200 flex items-center justify-center"
							>
								<div class="text-center">
									<div
										class="text-4xl md:text-5xl font-bold text-teal-600"
									>
										100%
									</div>
									<div
										class="text-sm md:text-base text-teal-700 font-medium"
									>
										Full Enrollment
									</div>
								</div>
							</div>
							<div
								class="absolute -bottom-4 -right-4 w-24 h-24 md:w-32 md:h-32 rounded-full bg-gradient-to-br from-amber-100 to-amber-200 flex items-center justify-center shadow-lg"
							>
								<div class="text-center">
									<div
										class="text-xl md:text-2xl font-bold text-amber-600"
									>
										50%
									</div>
									<div class="text-xs text-amber-700">
										Partial
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- SEO SECTION 4: Operations & Staffing -->
	<section
		class="py-16 md:py-24 px-4 md:px-6 bg-gradient-to-b from-white/30 to-transparent"
	>
		<div class="max-w-6xl mx-auto text-center">
			<span
				class="inline-block px-4 py-2 rounded-full bg-purple-100 text-purple-700 text-sm font-semibold mb-4"
			>
				The Foundation
			</span>
			<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
				Operations, Staffing & Benefits
			</h2>
			<p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto mb-12">
				Your team is everything. Staffing is your biggest investment—and
				your greatest opportunity. But you can't plan your team until
				you know what you can sustain.
			</p>

			<div
				class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto mb-12"
			>
				<div
					class="glass-panel rounded-3xl p-8 hover:shadow-xl transition-all duration-300"
				>
					<div
						class="w-14 h-14 mx-auto mb-4 rounded-full bg-gradient-to-br from-rose-400 to-rose-600 flex items-center justify-center"
					>
						<svg
							class="w-7 h-7 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
							></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-2">
						The Right Team
					</h3>
					<p class="text-gray-600">
						Teachers who share your vision. Benefits that keep them.
					</p>
				</div>

				<div
					class="glass-panel rounded-3xl p-8 hover:shadow-xl transition-all duration-300"
				>
					<div
						class="w-14 h-14 mx-auto mb-4 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center"
					>
						<svg
							class="w-7 h-7 text-white"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
							></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-2">
						Sustainable Growth
					</h3>
					<p class="text-gray-600">
						A plan that works today and scales tomorrow.
					</p>
				</div>
			</div>

			<div
				class="glass-panel rounded-3xl p-8 md:p-10 border-2 border-purple-200/50 bg-gradient-to-br from-purple-50/50 to-white/50 max-w-2xl mx-auto"
			>
				<p class="text-lg md:text-xl text-gray-700 mb-6">
					It all starts with knowing what you can build.
				</p>
				<a
					href="#calculator"
					class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-700 font-semibold text-lg group"
				>
					Let's figure that out together
					<svg
						class="w-5 h-5 group-hover:translate-x-1 transition-transform"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
					</svg>
				</a>
			</div>
		</div>
	</section>

	<!-- SOCIAL PROOF -->
	<section
		class="py-16 md:py-24 px-4 bg-gradient-to-b from-white/50 to-transparent"
	>
		<div class="max-w-5xl mx-auto">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
					You're Not Alone in This
				</h2>
				<p class="text-lg md:text-xl text-gray-600">
					Hundreds of women just like you have started here.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div
					class="glass-panel rounded-3xl p-8 hover:shadow-xl transition-all duration-300"
				>
					<div class="flex items-center gap-4 mb-4">
						<div
							class="w-14 h-14 rounded-full bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center text-white font-bold text-xl"
						>
							S
						</div>
						<div>
							<h4 class="font-bold text-gray-900">
								Sarah Jenkins
							</h4>
							<p class="text-sm text-gray-500">
								Little Stars Academy • Houston, TX
							</p>
						</div>
					</div>
					<p class="text-gray-700 italic text-lg">
						"I spent months reading everything I could find online.
						Nothing made sense until I saw my own numbers. That's
						when it clicked."
					</p>
				</div>

				<div
					class="glass-panel rounded-3xl p-8 hover:shadow-xl transition-all duration-300"
				>
					<div class="flex items-center gap-4 mb-4">
						<div
							class="w-14 h-14 rounded-full bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center text-white font-bold text-xl"
						>
							M
						</div>
						<div>
							<h4 class="font-bold text-gray-900">
								Michelle Torres
							</h4>
							<p class="text-sm text-gray-500">
								Bright Beginnings • Denver, CO
							</p>
						</div>
					</div>
					<p class="text-gray-700 italic text-lg">
						"I was scared to commit. Seeing the revenue potential
						for my state gave me the confidence to take the next
						step."
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- FINAL CLOSING -->
	<section class="py-16 md:py-24 px-4">
		<div class="max-w-3xl mx-auto text-center">
			<div
				class="glass-panel rounded-3xl p-10 md:p-14 border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/30 to-white/50"
			>
				<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
					Your Journey Starts with Clarity
				</h2>
				<p class="text-lg md:text-xl text-gray-600 mb-8">
					You don't need to have it all figured out. You just need to
					know if the numbers work. Everything else comes after.
				</p>

				<a
					href="#calculator"
					class="inline-block bg-teal-600 hover:bg-teal-700 text-white text-lg font-semibold px-10 py-4 rounded-full shadow-xl shadow-teal-600/30 transition-all hover:shadow-2xl hover:-translate-y-1"
				>
					See What's Possible for Me
				</a>
			</div>
		</div>
	</section>

	<EmailModal client:load />
</Layout>

