---
import { Container } from "../layout/Container";
---

<!-- FINAL CLOSING -->
<section class="py-16 md:py-24">
    <Container size="md">
        <div class="text-center">
            <div
                class="glass-panel rounded-3xl p-10 md:p-14 border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/30 to-white/50"
            >
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                    Your Daycare Journey Starts with Clarity
                </h2>
                <p class="text-lg md:text-xl text-gray-600 mb-8">
                    You don't need to have it all figured out. You just need to
                    know if the numbers work. Everything else comes after.
                </p>

                <a
                    href="#calculator"
                    class="inline-block bg-teal-600 hover:bg-teal-700 text-white text-lg font-semibold px-10 py-4 rounded-full shadow-xl shadow-teal-600/30 transition-all hover:shadow-2xl hover:-translate-y-1"
                >
                    See What's Possible for Me
                </a>
            </div>
        </div>
    </Container>
</section>
