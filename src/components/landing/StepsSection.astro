---
import { Container } from "../layout/Container";
import { Calculator, Shield, ArrowRight } from "lucide-react";

const steps = [
    {
        title: "Know Your Numbers",
        description: "Before the paperwork, before the location hunt—clarity on what's possible.",
        icon: Calculator,
        color: "from-teal-400 to-teal-600",
        shadow: "shadow-teal-500/20"
    },
    {
        title: "State Requirements",
        description: "Every state has unique rules. Your plan has to fit your reality.",
        icon: Shield,
        color: "from-purple-400 to-purple-600",
        shadow: "shadow-purple-500/20"
    },
    {
        title: "Your Unique Path",
        description: "Generic advice doesn't work. You need a plan built for your situation.",
        icon: ArrowRight,
        color: "from-amber-400 to-amber-600",
        shadow: "shadow-amber-500/20"
    }
];
---

<!-- SEO SECTION 1: Steps to Opening -->
<section class="pro-section bg-gray-50/50">
    <Container size="lg">
        <div class="text-center mb-6">
            <span class="pro-text-meta mb-2 block">The Journey</span>
            <h2 class="text-xl md:text-3xl font-bold text-gray-900 mb-2">
                Steps to Opening a Daycare
            </h2>
            <p class="text-sm md:text-base text-gray-600 max-w-2xl mx-auto">
                Opening a daycare isn't something you figure out from a blog post. The path looks different for everyone.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-6 mb-6">
            {steps.map((step) => (
                <div class="pro-card flex md:flex-col items-center md:text-center gap-4 md:gap-4 group">
                    <div class={`pro-icon-box shrink-0 bg-gradient-to-br ${step.color} ${step.shadow}`}>
                        <step.icon className="w-4 h-4 text-white" />
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900 text-sm md:text-lg mb-1 md:mb-2">{step.title}</h3>
                        <p class="text-xs md:text-sm text-gray-600 leading-relaxed">{step.description}</p>
                    </div>
                </div>
            ))}
        </div>

        <div class="pro-card text-center border-2 border-teal-200/30 bg-gradient-to-br from-teal-50/30 to-white/50">
            <p class="text-sm md:text-lg text-gray-700 mb-3">
                The first step isn't paperwork. It's clarity.
            </p>
            <a href="#calculator" class="inline-flex items-center gap-1.5 text-teal-600 hover:text-teal-700 font-bold text-sm md:text-base group">
                Let's start with your numbers
                <ArrowRight className="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
            </a>
        </div>
    </Container>
</section>
