---
import Layout from "@/layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import AuthorCard from "@/components/blog/AuthorCard.astro";
import BlogCTA from "@/components/blog/BlogCTA.astro";
import { getAllPosts, calculateReadTime } from "@/lib/blog";
import type { GetStaticPaths } from "astro";

import { render } from 'astro:content';

export const getStaticPaths = (async () => {
    const posts = await getAllPosts();
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}) satisfies GetStaticPaths;

import GlassParagraph from "@/components/blog/GlassParagraph.astro";

import { getCategoryStyle, getSeoAlt } from "@/config/blog";

const { post } = Astro.props;
const { title, excerpt, coverImage, category, date } = post.data;
const { Content } = await render(post);
const readTime = calculateReadTime(post.body || '');

const cover = coverImage || "/images/blog/default-cover.webp";

const categoryClass = getCategoryStyle(category);

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    image: new URL(
        cover,
        Astro.site || "https://childcarebusinessplan.com",
    ).toString(),
    datePublished: new Date(date).toISOString(),
    author: {
        "@type": "Person",
        name: "Childcare Business Plan Team", // Default, could be extended if author data exists
    },
    articleSection: category,
    description: excerpt,
};
---

<Layout title={`${title} | Blog`} description={excerpt}>
    <section class="py-8 md:py-16">
        <Container size="md">
            <!-- Back Link -->
            <a
                href="/blog"
                class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold mb-6 text-sm md:text-base min-h-[44px]"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to Blog
            </a>

            <!-- Cover Image -->
            <div
                class="aspect-[3/2] md:aspect-[21/9] rounded-2xl overflow-hidden mb-6 bg-gray-100"
            >
                <img
                    src={cover}
                    alt={getSeoAlt(title, category || "")}
                    class="w-full h-full object-cover"
                />
            </div>

            <!-- Meta -->
            <div class="mb-6">
                {
                    category && (
                        <span
                            class={`inline-block px-3 py-1.5 rounded-full text-sm font-semibold mb-3 ${categoryClass}`}
                        >
                            {category}
                        </span>
                    )
                }
                <h1 class="text-2xl md:text-4xl font-bold text-gray-900 mb-4">
                    {title}
                </h1>
                <div
                    class="flex items-center gap-3 text-xs md:text-sm text-gray-500"
                >
                    <AuthorCard post={post} />
                    <span>·</span>
                    <time datetime={date}>
                        {
                            new Date(date + "T12:00:00").toLocaleDateString("en-US", {
                                month: "long",
                                day: "numeric",
                                year: "numeric",
                            })
                        }
                    </time>
                    <span>·</span>
                    <span>{readTime}</span>
                </div>
            </div>

            <!-- Content -->
            <article
                class="prose max-w-none prose-p:text-sm md:prose-p:text-base prose-headings:font-bold prose-headings:text-gray-900 prose-a:text-teal-600 prose-img:rounded-xl mb-8 md:mb-12"
            >
                <Content components={{ p: GlassParagraph }} />
            </article>

            <!-- CTA -->
            <BlogCTA
                title="What Could Your Childcare Business Earn?"
                description="Get personalized income projections based on your state and goals."
                buttonText="See My Income Potential"
            />
        </Container>
    </section>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>
