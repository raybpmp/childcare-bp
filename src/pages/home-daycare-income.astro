---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import HeroImage from "../components/ui/HeroImage.astro";
---

<Layout
    title="Home Daycare Income | Childcare Business Plan"
    description="Home daycare income potential depends on your state's capacity limits, local market rates, and CACFP participation. Get personalized estimates for your situation."
>
    <!-- HERO SECTION -->
    <section class="pt-8 pb-12 md:pt-12 md:pb-20">
        <Container size="md">
            <HeroImage
                src="/images/startup/home-daycare-income.webp"
                alt="Cozy home-based learning environment representative of a successful home daycare business plan execution"
                className="mb-8 md:mb-12"
            />
            <div class="text-center mb-8 md:mb-12">
                <span
                    class="inline-block px-3 py-1 rounded-full bg-teal-100 text-teal-700 text-xs font-semibold mb-3"
                >
                    Income Insights
                </span>
                <h1
                    class="text-2xl md:text-5xl font-bold text-gray-900 mb-4 md:mb-6"
                >
                    YOUR Income Potential
                </h1>
                <p class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto">
                    Home daycare income isn't a fixed number—it's determined by
                    your state's capacity regulations, your local market's rate
                    structure, and your ability to maintain full enrollment.
                </p>
            </div>
        </Container>
    </section>

    <!-- FACTORS SECTION -->
    <section class="py-8 md:py-16">
        <Container size="md">
            <div
                class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10 mb-6 md:mb-8"
            >
                <h2
                    class="text-xl md:text-2xl font-bold text-gray-900 mb-4 md:mb-6"
                >
                    What Affects Your Income
                </h2>
                <div
                    class="space-y-4 text-sm md:text-base text-gray-600 leading-relaxed"
                >
                    <p>
                        Your income ceiling is set by your state's capacity
                        limits for family childcare providers. Some states allow
                        12 children with an assistant, others cap you at 6
                        without help. This single regulation can double or halve
                        your maximum revenue.
                    </p>
                    <p>
                        Local market rates create the other half of the
                        equation. Affluent suburbs might support premium pricing
                        that dramatically increases your per-child revenue.
                        Rural areas or lower-income communities might require
                        competitive pricing that limits what you can charge.
                    </p>
                    <p>
                        Additional revenue streams matter too. CACFP
                        reimbursement for meals can add significant income for
                        providers serving eligible families. Before and after
                        school care, drop-in rates, and summer programs create
                        opportunities beyond traditional full-time enrollment.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- WHY GENERIC FAILS SECTION -->
    <section class="py-8 md:py-16">
        <Container size="md">
            <div class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10">
                <h2
                    class="text-xl md:text-2xl font-bold text-gray-900 mb-4 md:mb-6"
                >
                    Why Online Advice Often Conflicts
                </h2>
                <div
                    class="space-y-4 text-sm md:text-base text-gray-600 leading-relaxed"
                >
                    <p>
                        Generic income estimates for home daycares range from
                        barely minimum wage to six-figure incomes. Both are
                        possible, but they describe completely different
                        regulatory environments, market conditions, and business
                        models.
                    </p>
                    <p>
                        The median income statistics you find online blend
                        together providers at different capacity levels, in
                        different markets, with different enrollment rates. They
                        can't tell you what's possible for you specifically.
                    </p>
                    <p>
                        You need to see numbers that reflect your state's
                        capacity limits, your local market rates, and realistic
                        enrollment scenarios. That's the only way to evaluate
                        whether a home daycare represents a viable income
                        opportunity for you.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- CTA SECTION -->
    <section class="py-12 md:py-20">
        <Container size="md">
            <div
                class="glass-panel rounded-2xl md:rounded-3xl p-6 md:p-10 text-center border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/50 to-white/50"
            >
                <h2
                    class="text-xl md:text-2xl font-bold text-gray-900 mb-3 md:mb-4"
                >
                    See How Much YOU Could Make in Your State
                </h2>
                <p class="text-sm md:text-base text-gray-600 mb-4 md:mb-6">
                    Get your personalized income estimate based on your state's
                    family daycare regulations and local market rates.
                </p>
                <a
                    href="/#calculator"
                    class="inline-flex items-center justify-center rounded-full bg-teal-600 hover:bg-teal-700 text-white font-medium px-6 py-3 md:px-8 md:py-4 shadow-lg transition-all text-sm md:text-base"
                >
                    Use the Free Calculator →
                </a>
            </div>
        </Container>
    </section>
</Layout>
