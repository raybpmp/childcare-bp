---
import "../styles/global.css";
import PortalSidebar from "@/components/portal/PortalSidebar.astro";
import PortalHeader from "@/components/portal/PortalHeader.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-[#f8f9fc]">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Childcare Business Plan Portal" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
	</head>
	<body class="min-h-screen font-inter text-gray-900 antialiased selection:bg-teal-100 selection:text-teal-900">
		<div class="flex h-screen overflow-hidden bg-[#f8f9fc]">
			<!-- Sidebar -->
			<PortalSidebar />

			<!-- Main Content Wrapper -->
			<div class="flex-1 flex flex-col md:ml-64 w-full h-full overflow-hidden">
				<!-- Header -->
				<PortalHeader />

				<!-- Page Content -->
				<main class="flex-1 overflow-x-hidden overflow-y-auto bg-[#f8f9fc] p-4 md:p-6 lg:p-8">
					<slot />
				</main>
			</div>
		</div>

        <script>
            // Listen for logout event dispatched from sidebar
            window.addEventListener('portal-logout', async () => {
                try {
                    // Need to dynamically import to use inside Astro script tag context safely
                    const { auth, signOut } = await import('@/lib/firebase-client');
                    await signOut(auth);
                    window.location.href = '/login';
                } catch (error) {
                    console.error('Logout error:', error);
                }
            });
        </script>
	</body>
</html>
