---
interface Props {
  label: string;
  value: string;
  trend?: string;
  trendDirection?: 'up' | 'down' | 'neutral';
  color?: 'brand' | 'blue' | 'purple' | 'orange';
}

const { label, value, trend, trendDirection = 'up', color = 'brand' } = Astro.props;

const colorStyles = {
  brand: 'text-brand-600 bg-brand-50 border-brand-100',
  blue: 'text-blue-600 bg-blue-50 border-blue-100',
  purple: 'text-purple-600 bg-purple-50 border-purple-100',
  orange: 'text-orange-600 bg-orange-50 border-orange-100',
};

const trendColors = {
  up: 'text-green-600',
  down: 'text-red-600',
  neutral: 'text-gray-500',
};
---

<div class="glass-panel flex flex-col p-3 rounded-xl border-white/40 shadow-sm">
  <span class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">{label}</span>
  <div class="flex items-end justify-between">
    <span class="text-xl font-bold text-gray-900">{value}</span>
    {trend && (
      <span class={`text-xs font-medium px-1.5 py-0.5 rounded-md ${trendColors[trendDirection]} bg-white/50`}>
        {trendDirection === 'up' ? '↑' : trendDirection === 'down' ? '↓' : '→'} {trend}
      </span>
    )}
  </div>
</div>
