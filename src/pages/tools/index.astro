---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Daycare Business Plan Tools">
    <div class="relative min-h-[90vh] bg-[#fafaf8] overflow-hidden selection:bg-teal-100 selection:text-teal-900">
        
        {/* Background Gradients */}
        <div class="absolute inset-x-0 top-0 h-96 overflow-hidden pointer-events-none">
            <div class="absolute -top-24 -left-20 w-[30rem] h-[30rem] rounded-full bg-teal-100/50 blur-[64px]"></div>
            <div class="absolute top-10 right-0 w-[40rem] h-[40rem] rounded-full bg-blue-50/40 blur-[80px]"></div>
        </div>

        <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 mt-12 md:mt-20">
            <div class="text-center max-w-3xl mx-auto mb-16 md:mb-24">
                <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-teal-50 border border-teal-100 text-teal-700 text-xs font-bold uppercase tracking-widest mb-6 shadow-sm">
                    <span class="relative flex h-2 w-2">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
                    </span>
                    Childcare Software Hub
                </span>
                <h1 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight mb-6 leading-tight">
                    Daycare Business Plan Tools &<br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-600 to-teal-400">Childcare Calculators</span>
                </h1>
                <p class="text-lg md:text-xl text-gray-600 font-medium leading-relaxed max-w-2xl mx-auto">
                    Free childcare management software tools to calculate the cost to open a daycare, set market pricing, and forecast your business plan revenue.
                </p>
            </div>

            {/* Tools Grid */}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12 relative z-10">
                
                {/* TOOL: Market Report */}
                <a href="/tools/market-report" class="group block h-full">
                    <div class="h-full bg-white/60 backdrop-blur-3xl border-2 border-white/80 rounded-[2rem] p-8 md:p-10 shadow-[0_8px_40px_-12px_rgba(0,0,0,0.05)] hover:shadow-[0_20px_60px_-15px_rgba(13,148,136,0.15)] hover:border-teal-100 transition-all duration-500 flex flex-col relative overflow-hidden">
                        
                        {/* Decorative Background Element */}
                        <div class="absolute -right-10 -top-10 w-40 h-40 bg-teal-50 rounded-full blur-3xl group-hover:bg-teal-100 transition-colors duration-500"></div>

                        {/* Aesthetic Header */}
                        <div class="flex items-center gap-4 mb-8 relative z-10">
                            <div class="w-14 h-14 bg-gradient-to-br from-teal-500 to-teal-700 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-teal-600/20 group-hover:scale-110 transition-transform duration-500">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                                </svg>
                            </div>
                            <div>
                                <h2 class="text-2xl font-black text-gray-900 tracking-tight group-hover:text-teal-700 transition-colors">Market Intelligence</h2>
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mt-1">Live Demographic Data</p>
                            </div>
                        </div>

                        {/* Visual Mockup Area */}
                        <div class="mb-8 rotate-1 group-hover:rotate-0 transition-transform duration-500 relative z-10 w-full glass-panel-warm p-4 rounded-xl border border-teal-100/30">
                            <div class="flex justify-between items-end mb-3">
                                <div>
                                    <div class="text-[9px] font-black uppercase text-gray-400 tracking-widest leading-none mb-1">Median Price Forecast</div>
                                    <div class="text-3xl font-black text-gray-900 leading-none">$385<span class="text-sm text-gray-400">/wk</span></div>
                                </div>
                                <div class="bg-teal-50 text-teal-700 text-xs font-bold px-2 py-1 rounded-md">Infant Center</div>
                            </div>
                            <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden flex">
                                <div class="h-full bg-teal-500 w-1/3"></div>
                                <div class="h-full bg-teal-300 w-1/4"></div>
                                <div class="h-full bg-teal-100 w-1/5"></div>
                            </div>
                        </div>

                        {/* Body content */}
                        <div class="flex-grow relative z-10">
                            <p class="text-gray-600 font-medium leading-relaxed">
                                Access the latest federal data from the U.S. Dept. of Labor for all 3,100+ counties. See precise childcare pricing floors, demographic breakdowns, and median family incomes for your target neighborhood.
                            </p>
                        </div>

                        {/* CTA styling */}
                        <div class="mt-8 pt-6 border-t border-gray-100 flex justify-between items-center relative z-10">
                             <span class="text-sm font-bold text-teal-600 group-hover:text-teal-800 transition-colors">Open Dashboard</span>
                             <div class="w-8 h-8 rounded-full bg-teal-50 flex items-center justify-center text-teal-600 group-hover:bg-teal-600 group-hover:text-white transition-all">
                                 <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                                </svg>
                             </div>
                        </div>
                    </div>
                </a>

                {/* TOOL: Income Builder */}
                <a href="/tools/income-builder" class="group block h-full">
                    <div class="h-full bg-white/60 backdrop-blur-3xl border-2 border-white/80 rounded-[2rem] p-8 md:p-10 shadow-[0_8px_40px_-12px_rgba(0,0,0,0.05)] hover:shadow-[0_20px_60px_-15px_rgba(107,33,168,0.15)] hover:border-purple-100 transition-all duration-500 flex flex-col relative overflow-hidden">
                        
                        {/* Decorative Background Element */}
                        <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-purple-50 rounded-full blur-3xl group-hover:bg-purple-100 transition-colors duration-500"></div>

                        {/* Aesthetic Header */}
                        <div class="flex items-center gap-4 mb-8 relative z-10">
                            <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-purple-700 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-purple-600/20 group-hover:scale-110 transition-transform duration-500">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                            </div>
                            <div>
                                <h2 class="text-2xl font-black text-gray-900 tracking-tight group-hover:text-purple-700 transition-colors">Income Builder</h2>
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mt-1">Provider Revenue Engine</p>
                            </div>
                        </div>

                        {/* Visual Mockup Area */}
                        <div class="mb-8 -rotate-1 group-hover:rotate-0 transition-transform duration-500 relative z-10 w-full glass-panel p-4 rounded-xl border border-purple-100/30">
                            <div class="flex gap-2 mb-3">
                                <div class="flex-1 bg-white p-2 rounded-lg border border-gray-100 text-center shadow-sm">
                                    <div class="text-[9px] font-black uppercase text-gray-400">Infants</div>
                                    <div class="text-lg font-black text-purple-700">4</div>
                                </div>
                                <div class="flex-1 bg-white p-2 rounded-lg border border-gray-100 text-center shadow-sm">
                                    <div class="text-[9px] font-black uppercase text-gray-400">Toddlers</div>
                                    <div class="text-lg font-black text-purple-700">6</div>
                                </div>
                            </div>
                            <div class="flex justify-between items-center mt-3 pt-3 border-t border-dashed border-gray-200">
                                <div class="text-[10px] font-black text-gray-400 uppercase">Estimated Annual</div>
                                <div class="text-xl font-black text-gray-900">$185k+</div>
                            </div>
                        </div>

                        {/* Body content */}
                        <div class="flex-grow relative z-10">
                            <p class="text-gray-600 font-medium leading-relaxed">
                                Calculate your precise revenue potential. Map out your age groups, factor in your state's specific subsidy floors (HHS/CCDF) and food program reimbursements (USDA CACFP) to find your maximum yield ratio.
                            </p>
                        </div>

                         {/* CTA styling */}
                        <div class="mt-8 pt-6 border-t border-gray-100 flex justify-between items-center relative z-10">
                             <span class="text-sm font-bold text-purple-600 group-hover:text-purple-800 transition-colors">Open Calculator</span>
                             <div class="w-8 h-8 rounded-full bg-purple-50 flex items-center justify-center text-purple-600 group-hover:bg-purple-600 group-hover:text-white transition-all">
                                 <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                                </svg>
                             </div>
                        </div>
                    </div>
                </a>

                {/* TOOL: Business Modeler */}
                <a href="/tools/business-modeler" class="group block h-full">
                    <div class="h-full bg-white/60 backdrop-blur-3xl border-2 border-white/80 rounded-[2rem] p-8 md:p-10 shadow-[0_8px_40px_-12px_rgba(0,0,0,0.05)] hover:shadow-[0_20px_60px_-15px_rgba(37,99,235,0.15)] hover:border-blue-100 transition-all duration-500 flex flex-col relative overflow-hidden">
                        
                        {/* Decorative Background Element */}
                        <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-blue-50 rounded-full blur-3xl group-hover:bg-blue-100 transition-colors duration-500"></div>

                        {/* Aesthetic Header */}
                        <div class="flex items-center gap-4 mb-8 relative z-10">
                            <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-blue-700 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-blue-600/20 group-hover:scale-110 transition-transform duration-500">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V13.5Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V18Zm2.498-6.75h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V13.5Zm0 2.25h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V18Zm2.502-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5Zm0 2.25h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V18ZM4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
                                </svg>
                            </div>
                            <div>
                                <h2 class="text-2xl font-black text-gray-900 tracking-tight group-hover:text-blue-700 transition-colors">Business Modeler</h2>
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mt-1">Startup Costs</p>
                            </div>
                        </div>

                        {/* Visual Mockup Area */}
                        <div class="mb-8 rotate-1 group-hover:rotate-0 transition-transform duration-500 relative z-10 w-full glass-panel-warm p-4 rounded-xl border border-blue-100/30">
                            <div class="flex justify-between items-end mb-3">
                                <div>
                                    <div class="text-[9px] font-black uppercase text-gray-400 tracking-widest leading-none mb-1">Total Needed</div>
                                    <div class="text-3xl font-black text-blue-900 leading-none">$85k<span class="text-sm text-gray-400"> capital</span></div>
                                </div>
                                <div class="bg-blue-50 text-blue-700 text-xs font-bold px-2 py-1 rounded-md">Center</div>
                            </div>
                            <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden flex">
                                <div class="h-full bg-blue-500 w-1/2"></div>
                                <div class="h-full bg-slate-300 w-1/4"></div>
                            </div>
                        </div>

                        {/* Body content */}
                        <div class="flex-grow relative z-10">
                            <p class="text-gray-600 font-medium leading-relaxed">
                                Estimate your startup costs and profitability. Toggle inflation conditions to simulate 2026 local market conditions including hard market insurance spikes and construction costs.
                            </p>
                        </div>

                        {/* CTA styling */}
                        <div class="mt-8 pt-6 border-t border-gray-100 flex justify-between items-center relative z-10">
                             <span class="text-sm font-bold text-blue-600 group-hover:text-blue-800 transition-colors">Open Modeler</span>
                             <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all">
                                 <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                                </svg>
                             </div>
                        </div>
                    </div>
                </a>

            </div>
        </div>
    </div>
</Layout>
