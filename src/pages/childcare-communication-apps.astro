---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import HeroImage from "../components/ui/HeroImage.astro";
import { ArrowRight } from "lucide-react";
---

<Layout
    title="Childcare Communication Apps | Childcare Business Plan"
    description="Evaluate childcare communication apps based on staff adoption and parent expectations, not just features."
>
    <!-- HERO SECTION -->
    <section class="pro-section">
        <Container size="md">
            <HeroImage
                src="/images/growth/childcare-communication-apps.webp"
                alt="Tablet interface displaying parent engagement features found in leading childcare communication apps"
                className="mb-4 md:mb-12"
            />
            <div class="text-center">
                <span class="pro-text-meta mb-2 block text-purple-600">
                    Operations
                </span>
                <h1 class="text-xl md:text-5xl font-bold text-gray-900 mb-2 md:mb-6">
                    YOUR Parent Communication
                </h1>
                <p class="text-sm md:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
                    Great communication isn't about which app you use—it's about building trust and transparency with the families you serve.
                </p>
            </div>
        </Container>
    </section>

    <!-- FACTORS SECTION -->
    <section class="pro-section bg-gray-50/50">
        <Container size="md">
            <div class="pro-card mb-3 md:mb-8">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-6 uppercase tracking-wider">
                    What Affects App Success
                </h2>
                <div class="space-y-3 text-xs md:text-base text-gray-600 leading-relaxed font-medium">
                    <p>
                        The success of any tool depends entirely on your staff's willingness to adopt it and your parents' expectations for updates.
                    </p>
                    <p>
                        A feature-rich app is useless if your team finds it too cumbersome to use during a busy day. Simplicity often wins in a childcare setting.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- WHY GENERIC FAILS SECTION -->
    <section class="pro-section">
        <Container size="md">
            <div class="pro-card">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-6 uppercase tracking-wider">
                    Why Advice Conflicts
                </h2>
                <div class="space-y-3 text-xs md:text-base text-gray-600 leading-relaxed font-medium">
                    <p>
                        Tech reviews often focus on feature lists rather than real-world usability in a childcare setting.
                    </p>
                    <p>
                        Your choice should be driven by your specific workflow and the level of engagement your parents actually want, not a salesperson's pitch.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- CTA SECTION -->
    <section class="pro-section">
        <Container size="md">
            <div class="pro-card text-center border-2 border-purple-200/50 bg-gradient-to-br from-purple-50/20 to-white/50">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-4">
                    See Real Tech ROI
                </h2>
                <p class="text-xs md:text-base text-gray-600 mb-3 md:mb-6">
                    Get your personalized income estimate to see how technology investment impacts your bottom line.
                </p>
                <a
                    href="/#calculator"
                    class="inline-flex items-center gap-1.5 justify-center rounded-full bg-purple-600 hover:bg-purple-700 text-white font-bold px-5 py-2 md:px-8 md:py-4 shadow-lg transition-all text-xs md:text-base group"
                >
                    Use the Free Calculator
                    <ArrowRight className="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" />
                </a>
            </div>
        </Container>
    </section>
</Layout>
