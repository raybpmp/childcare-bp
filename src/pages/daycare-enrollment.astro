---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import HeroImage from "../components/ui/HeroImage.astro";
import { ArrowRight } from "lucide-react";
---

<Layout
    title="Daycare Enrollment Strategies | Childcare Business Plan"
    description="Master your daycare enrollment strategy by optimizing waitlists and capacity management for your specific center."
>
    <!-- HERO SECTION -->
    <section class="pro-section">
        <Container size="md">
            <HeroImage
                src="/images/growth/daycare-enrollment.webp"
                alt="Busy reception area illustrating high capacity achieved through targeted daycare marketing strategies"
                className="mb-4 md:mb-12"
            />
            <div class="text-center">
                <span class="pro-text-meta mb-2 block text-purple-600">
                    Capacity Management
                </span>
                <h1 class="text-xl md:text-5xl font-bold text-gray-900 mb-2 md:mb-6">
                    YOUR Enrollment Strategy
                </h1>
                <p class="text-sm md:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
                    Keeping your center full is an active process of managing relationships and timing. It's not a passive result of just having a website.
                </p>
            </div>
        </Container>
    </section>

    <!-- FACTORS SECTION -->
    <section class="pro-section bg-gray-50/50">
        <Container size="md">
            <div class="pro-card mb-3 md:mb-8">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-6 uppercase tracking-wider">
                    What Affects Your Capacity
                </h2>
                <div class="space-y-3 text-xs md:text-base text-gray-600 leading-relaxed font-medium">
                    <p>
                        Your ability to maintain full enrollment is dictated by effective waitlist management, understanding your churn rates, and optimizing your licensed capacity.
                    </p>
                    <p>
                        Balancing age groups and transitions is key to maximizing revenue without violating state regulations.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- WHY GENERIC FAILS SECTION -->
    <section class="pro-section">
        <Container size="md">
            <div class="pro-card">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-6 uppercase tracking-wider">
                    Why Generic Tips Fail
                </h2>
                <div class="space-y-3 text-xs md:text-base text-gray-600 leading-relaxed font-medium">
                    <p>
                        General tips often miss the operational complexity of managing "aging up" and spot availability.
                    </p>
                    <p>
                        Your strategy needs to align with your specific licensing capacity and the seasonal demand patterns of your local area.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- CTA SECTION -->
    <section class="pro-section">
        <Container size="md">
            <div class="pro-card text-center border-2 border-purple-200/50 bg-gradient-to-br from-purple-50/20 to-white/50">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-4">
                    See Real Enrollment Impact
                </h2>
                <p class="text-xs md:text-base text-gray-600 mb-3 md:mb-6">
                    Get your personalized income estimate to see the revenue impact of full enrollment.
                </p>
                <a
                    href="/#calculator"
                    class="inline-flex items-center gap-1.5 justify-center rounded-full bg-purple-600 hover:bg-purple-700 text-white font-bold px-5 py-2 md:px-8 md:py-4 shadow-lg transition-all text-xs md:text-base group"
                >
                    Use the Free Calculator
                    <ArrowRight className="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" />
                </a>
            </div>
        </Container>
    </section>
</Layout>
