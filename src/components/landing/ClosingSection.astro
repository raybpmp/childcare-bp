---
import { Container } from "../layout/Container";
import { ArrowRight } from "lucide-react";
---

<!-- FINAL CLOSING -->
<section class="pro-section">
    <Container size="md">
        <div class="pro-card text-center border-2 border-teal-200/50 bg-gradient-to-br from-teal-50/20 to-white/50">
            <h2 class="text-xl md:text-3xl font-bold text-gray-900 mb-2 md:mb-4">
                Your Daycare Journey Starts with Clarity
            </h2>
            <p class="text-sm md:text-lg text-gray-600 mb-4 md:mb-8 max-w-2xl mx-auto leading-relaxed">
                You don't need to have it all figured out. You just need to know if the numbers work. Everything else comes after.
            </p>

            <a
                href="#calculator"
                class="inline-flex items-center gap-2 bg-teal-600 hover:bg-teal-700 text-white text-sm md:text-lg font-bold px-6 py-2.5 md:px-10 md:py-4 rounded-full shadow-lg shadow-teal-600/20 transition-all hover:shadow-xl hover:-translate-y-0.5"
            >
                See What's Possible for Me
                <ArrowRight className="w-4 h-4 md:w-5 md:h-5" />
            </a>
        </div>
    </Container>
</section>
