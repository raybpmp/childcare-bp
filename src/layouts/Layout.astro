---
import "../styles/global.css";
import { Separator } from "@/components/ui/separator";
import { UserNav } from "@/components/auth/UserNav";
import { MobileNav } from "@/components/MobileNav";
import { ToolsGridMenu } from "@/components/tools/ToolsGridMenu";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Launch or fix your daycare business with a real plan.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link rel="preload" as="image" href="/background.webp" />

		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col">
		<!-- GLOBAL HEADER -->
		<header class="fixed top-0 left-0 right-0 z-50 p-2 sm:p-4">
			<nav
				class="glass-header mx-auto max-w-7xl rounded-full px-3 sm:px-6 py-1.5 sm:py-3 flex items-center justify-between shadow-lg shadow-black/5"
		>
			<!-- Left: Mobile Menu + Logo -->
				<div class="flex items-center gap-0.5 sm:gap-2">
				<MobileNav client:load />
					<a href="/" class="flex items-center gap-1.5 group transition-all shrink min-w-0">
						<div
							class="w-8 h-8 bg-gradient-to-br from-teal-400 to-teal-600 rounded-lg flex-shrink-0 flex items-center justify-center text-white font-bold group-hover:scale-105 transition-transform"
						>
					C
					</div>
					<span
						class="font-bold text-gray-900 tracking-tight text-xs sm:text-base whitespace-nowrap"
						>Childcare Business Plan</span
					>
				</a>
			</div>

			<!-- Center: Desktop Links (Hidden on Mobile) -->
			<div class="hidden md:flex items-center gap-8 absolute left-1/2 -translate-x-1/2">
				<a
					href="/childcarebusinessplans"
					class="text-sm font-medium text-gray-700 hover:text-teal-600 transition-colors"
				>
				Plans
				</a>
				<a
					href="/blog"
					class="text-sm font-medium text-gray-700 hover:text-teal-600 transition-colors"
				>
				Blog
				</a>
			</div>

			<!-- Right: Actions (Tools + Dashboard) -->
				<div class="flex items-center gap-0 sm:gap-2">
				<ToolsGridMenu client:load />
				<UserNav client:load />
			</div>
		</nav>
		</header>

		<!-- PAGE CONTENT -->
		<main class="flex-1 pt-16 md:pt-20">
			<slot />
		</main>

		<!-- GLOBAL FOOTER -->
		<footer class="glass-panel mt-auto py-6 md:py-8 px-4 border-t border-teal-200/10">
			<div class="max-w-5xl mx-auto">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 mb-6">
					<div>
						<div class="flex items-center gap-2 mb-4">
							<div
								class="w-8 h-8 bg-gradient-to-br from-teal-400 to-teal-600 rounded-lg flex items-center justify-center text-white font-bold"
							>
								C
							</div>
							<span class="font-bold text-gray-900"
								>Childcare Business Plan</span
							>
						</div>
						<p class="text-sm text-gray-600">
							The complete operating system for childcare founders
							and owners.
						</p>
					</div>
					<div>
						<h4 class="font-semibold text-gray-900 mb-4">
							Startup
						</h4>
						<ul class="space-y-2 text-sm text-gray-600">
							<li>
								<a
									href="/starting-a-daycare"
									class="hover:text-teal-600"
									>Starting a Daycare</a
								>
							</li>
							<li>
								<a
									href="/starting-a-daycare-at-home"
									class="hover:text-teal-600"
									>Starting a Daycare at Home</a
								>
							</li>
							<li>
								<a
									href="/steps-to-opening-a-daycare"
									class="hover:text-teal-600"
									>Steps to Opening a Daycare</a
								>
							</li>
							<li>
								<a
									href="/daycare-business-plan"
									class="hover:text-teal-600"
									>Daycare Business Plan</a
								>
							</li>
							<li>
								<a
									href="/cost-of-starting-a-daycare"
									class="hover:text-teal-600"
									>Cost of Starting a Daycare</a
								>
							</li>
							<li>
								<a
									href="/home-daycare-income"
									class="hover:text-teal-600"
									>Home Daycare Income</a
								>
							</li>
						</ul>
					</div>
					<div>
						<h4 class="font-semibold text-gray-900 mb-4">Growth</h4>
						<ul class="space-y-2 text-sm text-gray-600">
							<li>
								<a
									href="/childcare-employee-benefits"
									class="hover:text-purple-600"
									>Employee Benefits</a
								>
							</li>
							<li>
								<a
									href="/daycare-marketing"
									class="hover:text-purple-600"
									>Daycare Marketing</a
								>
							</li>
							<li>
								<a
									href="/childcare-communication-apps"
									class="hover:text-purple-600"
									>Communication Apps</a
								>
							</li>
							<li>
								<a
									href="/daycare-enrollment"
									class="hover:text-purple-600"
									>Daycare Enrollment</a
								>
							</li>
						</ul>
					</div>
					<div>
						<h4 class="font-semibold text-gray-900 mb-4">
							Company
						</h4>
						<ul class="space-y-2 text-sm text-gray-600">
							<li>
								<a href="/blog" class="hover:text-gray-900"
									>Blog</a
								>
							</li>
							<li>
								<a href="/about" class="hover:text-gray-900"
									>About</a
								>
							</li>
							<li>
								<a href="/contact" class="hover:text-gray-900"
									>Contact</a
								>
							</li>
						</ul>
					</div>
					<div>
						<h4 class="font-semibold text-gray-900 mb-4">Legal</h4>
						<ul class="space-y-2 text-sm text-gray-600">
							<li>
								<a href="/privacy" class="hover:text-gray-900"
									>Privacy Policy</a
								>
							</li>
							<li>
								<a href="/terms" class="hover:text-gray-900"
									>Terms of Service</a
								>
							</li>
						</ul>
					</div>
				</div>
				<Separator className="my-6" />
				<p class="text-center text-sm text-gray-500">
					© 2026 ChildcareBusinessPlan.com. All rights reserved.
				</p>
			</div>
		</footer>
		<!-- No additional scripts needed for navigation; UserNav handles auth state reactively. -->
	</body>
</html>
