---
import { Container } from "../layout/Container";
import QuizFunnel from "../tools/QuizFunnel";
---

<!-- QUIZ FUNNEL SECTION -->
<section id="calculator" class="pro-section">
    <Container size="md">
        <div class="pro-card text-center mb-3 md:mb-6 border-2 border-teal-200/20 bg-gradient-to-br from-teal-50/10 to-white/50">
            <span class="pro-text-meta inline-block mb-1.5 md:mb-3">
                ✨ 2-Minute Quiz
            </span>
            <h2 class="text-xl md:text-3xl font-bold mb-2 md:mb-3">
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-600 to-teal-500">
                    Discover Your Revenue Potential
                </span>
            </h2>
            <p class="text-xs md:text-lg text-gray-600 max-w-xl mx-auto leading-relaxed">
                Answer a few quick questions to see what's possible for you.
            </p>
        </div>
        <QuizFunnel client:load />
    </Container>
</section>
