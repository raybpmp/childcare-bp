---
interface Props {
    title: string;
    subtitle: string;
    badge?: string;
}

const { title, subtitle, badge = "Resources" } = Astro.props;
---

<div
    class="glass-panel rounded-2xl md:rounded-3xl p-5 md:p-10 text-center mb-6 md:mb-10"
>
    <span
        class="inline-block px-3 py-1.5 md:px-4 md:py-2 rounded-full bg-teal-100 text-teal-700 text-sm font-semibold mb-3 md:mb-5"
    >
        {badge}
    </span>
    <h1
        class="text-2xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-3 md:mb-4"
    >
        {title}
    </h1>
    <p class="text-base md:text-lg text-gray-600">
        {subtitle}
    </p>
</div>
