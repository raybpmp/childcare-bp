---
import Layout from '../layouts/Layout.astro';
import HeroSplit from '../components/HeroSplit';
import EmailModal from '../components/EmailModal';
import { Card, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
---

<Layout title="Childcare Business Plan | Launch & Grow Your Daycare">
	
	<!-- HERO SECTION -->
	<section class="min-h-screen flex items-center justify-center px-4">
		<HeroSplit client:load />
	</section>

	<!-- PROBLEM SECTION -->
	<section class="py-24 px-4 bg-gradient-to-b from-transparent to-white/50">
		<div class="max-w-5xl mx-auto text-center">
			<h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
				Opening a Daycare is <span class="text-red-500">Hard</span>
			</h2>
			<p class="text-xl text-gray-600 max-w-3xl mx-auto mb-12">
				82% of new childcare centers fail within 3 years. Not because the owners don't care — but because they didn't have a plan for licensing, staffing, finances, or enrollment.
			</p>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<div class="glass-panel rounded-2xl p-6 text-left">
					<div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
					</div>
					<h3 class="font-bold text-gray-900 mb-2">Licensing Confusion</h3>
					<p class="text-gray-600 text-sm">Every state has different requirements. Miss one form and you're delayed 6 months.</p>
				</div>
				
				<div class="glass-panel rounded-2xl p-6 text-left">
					<div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
					</div>
					<h3 class="font-bold text-gray-900 mb-2">Cash Flow Nightmare</h3>
					<p class="text-gray-600 text-sm">You're paying rent before you have kids enrolled. Most new owners run out of runway.</p>
				</div>
				
				<div class="glass-panel rounded-2xl p-6 text-left">
					<div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
						</svg>
					</div>
					<h3 class="font-bold text-gray-900 mb-2">Staffing Crisis</h3>
					<p class="text-gray-600 text-sm">You need qualified teachers before you open, but can't pay them until you have revenue.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- SOLUTION SECTION -->
	<section class="py-24 px-4">
		<div class="max-w-5xl mx-auto text-center">
			<span class="inline-block px-4 py-2 rounded-full bg-teal-100 text-teal-700 text-sm font-semibold mb-6">
				The Solution
			</span>
			<h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
				A Complete Roadmap to <span class="text-teal-600">Opening Day</span>
			</h2>
			<p class="text-xl text-gray-600 max-w-3xl mx-auto mb-16">
				We've helped 200+ childcare centers launch successfully. Now we've packaged everything into a toolkit you can use today.
			</p>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
				<div class="glass-panel rounded-3xl p-8 border-2 border-teal-100">
					<div class="flex items-start gap-4 mb-6">
						<div class="w-12 h-12 rounded-xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-gray-900 mb-2">Business Plan Template</h3>
							<p class="text-gray-600">A 30-page SBA-ready business plan customized for childcare. Banks love it.</p>
						</div>
					</div>
					<ul class="space-y-3">
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Market analysis section
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							5-year financial projections
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Competitive positioning
						</li>
					</ul>
				</div>
				
				<div class="glass-panel rounded-3xl p-8 border-2 border-teal-100">
					<div class="flex items-start gap-4 mb-6">
						<div class="w-12 h-12 rounded-xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-gray-900 mb-2">Budget Calculator</h3>
							<p class="text-gray-600">Know exactly how much you need before you sign a lease.</p>
						</div>
					</div>
					<ul class="space-y-3">
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Startup cost breakdown
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Monthly operating expenses
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Break-even analysis
						</li>
					</ul>
				</div>
				
				<div class="glass-panel rounded-3xl p-8 border-2 border-purple-100">
					<div class="flex items-start gap-4 mb-6">
						<div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-gray-900 mb-2">90-Day Launch Checklist</h3>
							<p class="text-gray-600">Week-by-week tasks from "idea" to "doors open."</p>
						</div>
					</div>
					<ul class="space-y-3">
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-purple-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Licensing timeline
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-purple-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Hiring milestones
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-purple-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Marketing launch plan
						</li>
					</ul>
				</div>
				
				<div class="glass-panel rounded-3xl p-8 border-2 border-purple-100">
					<div class="flex items-start gap-4 mb-6">
						<div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-400 to-purple-600 flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
							</svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-gray-900 mb-2">State Licensing Guide</h3>
							<p class="text-gray-600">Requirements for all 50 states, updated for 2026.</p>
						</div>
					</div>
					<ul class="space-y-3">
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-purple-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Staff-to-child ratios
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-purple-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Required certifications
						</li>
						<li class="flex items-center gap-3 text-gray-700">
							<svg class="w-5 h-5 text-purple-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
							Inspection checklists
						</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- SOCIAL PROOF SECTION -->
	<section class="py-24 px-4 bg-gradient-to-b from-white/50 to-transparent">
		<div class="max-w-5xl mx-auto">
			<div class="text-center mb-16">
				<h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
					Trusted by 200+ Childcare Founders
				</h2>
				<p class="text-xl text-gray-600">
					Here's what they're saying
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
				<div class="glass-panel rounded-2xl p-6 text-center">
					<div class="text-4xl font-bold text-teal-600 mb-2">40hrs</div>
					<p class="text-gray-600">Time saved on business planning</p>
				</div>
				<div class="glass-panel rounded-2xl p-6 text-center">
					<div class="text-4xl font-bold text-purple-600 mb-2">2x</div>
					<p class="text-gray-600">Higher loan approval rate</p>
				</div>
				<div class="glass-panel rounded-2xl p-6 text-center">
					<div class="text-4xl font-bold text-teal-600 mb-2">100%</div>
					<p class="text-gray-600">First-try licensing pass rate</p>
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div class="glass-panel rounded-2xl p-8">
					<div class="flex items-center gap-4 mb-4">
						<div class="w-12 h-12 rounded-full bg-gradient-to-br from-teal-400 to-teal-600"></div>
						<div>
							<h4 class="font-bold text-gray-900">Sarah Jenkins</h4>
							<p class="text-sm text-gray-500">Founder, Little Stars Academy • Houston, TX</p>
						</div>
					</div>
					<p class="text-gray-700 italic">
						"I was drowning in state licensing paperwork. This toolkit organized everything and I passed inspection on the first try. Opened 6 weeks ahead of schedule."
					</p>
				</div>

				<div class="glass-panel rounded-2xl p-8">
					<div class="flex items-center gap-4 mb-4">
						<div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-400 to-purple-600"></div>
						<div>
							<h4 class="font-bold text-gray-900">Michael Torres</h4>
							<p class="text-sm text-gray-500">Owner, Bright Beginnings • Denver, CO</p>
						</div>
					</div>
					<p class="text-gray-700 italic">
						"The financial projections helped me get a $150K SBA loan. The bank said it was one of the most thorough childcare business plans they'd seen."
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA SECTION -->
	<section id="toolkit" class="py-24 px-4">
		<div class="max-w-3xl mx-auto text-center">
			<div class="glass-panel rounded-3xl p-12 border-2 border-teal-200">
				<h2 class="text-4xl font-bold text-gray-900 mb-4">
					Ready to Open Your Doors?
				</h2>
				<p class="text-xl text-gray-600 mb-8">
					Get the complete toolkit free. We'll email you the business plan template, budget calculator, and 90-day checklist.
				</p>
				
				<form class="max-w-md mx-auto">
					<div class="flex flex-col sm:flex-row gap-3">
						<input 
							type="email" 
							placeholder="Enter your email" 
							class="flex-1 px-5 py-4 rounded-full border border-gray-200 bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500"
						/>
						<button 
							type="submit" 
							class="px-8 py-4 rounded-full bg-teal-600 hover:bg-teal-700 text-white font-semibold shadow-lg shadow-teal-600/30 transition-all hover:shadow-xl"
						>
							Get Free Toolkit
						</button>
					</div>
					<p class="text-sm text-gray-500 mt-4">
						No spam. Unsubscribe anytime.
					</p>
				</form>
			</div>
		</div>
	</section>

	<!-- Email Modal -->
	<EmailModal client:load />

</Layout>
