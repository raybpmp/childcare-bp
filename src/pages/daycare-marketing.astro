---
import Layout from "../layouts/Layout.astro";
import { Container } from "@/components/layout/Container";
import HeroImage from "../components/ui/HeroImage.astro";
import { ArrowRight } from "lucide-react";
---

<Layout
    title="Daycare Marketing Strategies | Childcare Business Plan"
    description="Discover effective daycare marketing strategies tailored to your local market competition and saturation levels."
>
    <!-- HERO SECTION -->
    <section class="pro-section">
        <Container size="md">
            <HeroImage
                src="/images/growth/daycare-marketing.webp"
                alt="Digital analytics screen showing enrollment growth metrics driven by effective daycare marketing strategies"
                className="mb-4 md:mb-12"
            />
            <div class="text-center">
                <span class="pro-text-meta mb-2 block text-purple-600">
                    Growth Strategy
                </span>
                <h1 class="text-xl md:text-5xl font-bold text-gray-900 mb-2 md:mb-6">
                    YOUR Enrollment Growth
                </h1>
                <p class="text-sm md:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
                    True growth comes from understanding that your center is a unique brand in your community, not just another option on a list.
                </p>
            </div>
        </Container>
    </section>

    <!-- FACTORS SECTION -->
    <section class="pro-section bg-gray-50/50">
        <Container size="md">
            <div class="pro-card mb-3 md:mb-8">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-6 uppercase tracking-wider">
                    What Affects Your Marketing Success
                </h2>
                <div class="space-y-3 text-xs md:text-base text-gray-600 leading-relaxed font-medium">
                    <p>
                        Your ability to fill spots depends heavily on local market saturation, the specific demographics of families in your radius, and the intensity of competition.
                    </p>
                    <p>
                        What works in a dense urban center will fail in a suburban setting. Your marketing approach must match your market reality.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- WHY GENERIC FAILS SECTION -->
    <section class="pro-section">
        <Container size="md">
            <div class="pro-card">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-6 uppercase tracking-wider">
                    Why Generic Tips Fail
                </h2>
                <div class="space-y-3 text-xs md:text-base text-gray-600 leading-relaxed font-medium">
                    <p>
                        Marketing gurus push expensive digital ads that may not reach your specific local parents.
                    </p>
                    <p>
                        Your plan needs to be built around your location and capacity goals, focusing on high-conversion local channels rather than broad campaigns.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- CTA SECTION -->
    <section class="pro-section">
        <Container size="md">
            <div class="pro-card text-center border-2 border-purple-200/50 bg-gradient-to-br from-purple-50/20 to-white/50">
                <h2 class="text-base md:text-2xl font-bold text-gray-900 mb-2 md:mb-4">
                    See YOUR Revenue Potential
                </h2>
                <p class="text-xs md:text-base text-gray-600 mb-3 md:mb-6">
                    Get your personalized income estimate to understand your revenue potential.
                </p>
                <a
                    href="/#calculator"
                    class="inline-flex items-center gap-1.5 justify-center rounded-full bg-purple-600 hover:bg-purple-700 text-white font-bold px-5 py-2 md:px-8 md:py-4 shadow-lg transition-all text-xs md:text-base group"
                >
                    Use the Free Calculator
                    <ArrowRight className="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" />
                </a>
            </div>
        </Container>
    </section>
</Layout>
