---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy | ChildcareBusinessPlan.com">
	<main class="min-h-screen p-4 md:p-8">
		<div class="max-w-4xl mx-auto">
			<div class="glass-panel rounded-3xl p-12">
				<h1 class="text-4xl font-bold text-gray-900 mb-8">Privacy Policy</h1>
				
				<div class="prose prose-gray max-w-none">
					<p class="text-gray-600 mb-6">Last updated: January 2026</p>

					<h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Information We Collect</h2>
					<p class="text-gray-600 mb-4">
						We collect email addresses when you opt-in to receive our toolkits and resources. We may also collect anonymous usage data to improve our website.
					</p>

					<h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">How We Use Your Information</h2>
					<p class="text-gray-600 mb-4">
						Your email is used solely to deliver the requested resources and occasional updates about childcare business planning. You can unsubscribe at any time.
					</p>

					<h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Data Security</h2>
					<p class="text-gray-600 mb-4">
						We implement industry-standard security measures to protect your personal information.
					</p>

					<h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Contact Us</h2>
					<p class="text-gray-600 mb-4">
						For privacy-related questions, email us at privacy@childcarebusinessplan.com
					</p>
				</div>

				<div class="mt-12 pt-8 border-t border-gray-200">
					<a href="/" class="text-brand-600 hover:text-brand-700 font-semibold">← Back to Home</a>
				</div>
			</div>
		</div>
	</main>
</Layout>
